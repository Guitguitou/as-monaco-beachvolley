<% content_for :hero do %>
  <%= render HeroComponent.new(
        title: "Boutique",
        subtitle: "Achetez vos crédits, licence, packs d'entraînement et équipements",
        variant: :red,
        flush_title: true,
        title_font: :anton
      ) do |hero| %>
    <% hero.with_eyebrow do %>
      <%= render BadgeComponent.new(label: "Crédits & Équipements", variant: :hero, size: :sm) %>
    <% end %>
    <% hero.with_actions do %>
      <% if current_user&.activated? %>
        <div class="w-full lg:w-auto flex justify-start">
          <div class="w-[170px] rounded-none border border-white/30 bg-white/10 px-3 py-2 text-white">
            <p class="text-[7px] font-semibold uppercase tracking-[0.22em] text-white/65 text-center leading-none">Vos crédits</p>
            <div class="mt-1.5 flex items-center justify-center gap-2.5">
              <div class="min-w-0">
                <span class="text-[46px] font-anton leading-[0.95] tabular-nums"><%= number_with_delimiter(@current_balance, delimiter: " ") %></span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<!-- Notice pour les comptes non activés -->
<% if @show_activation_notice %>
  <div class="mb-6 border-l-4 border-blue-500 bg-blue-50 p-4 rounded-none">
    <div class="flex items-start">
      <div class="flex-shrink-0">
        <%= lucide_icon("info", size: 20, class: "text-blue-600") %>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-blue-900">Bienvenue ! 👋</h3>
        <div class="mt-2 text-sm text-blue-800">
          <p class="mb-2">Votre compte n'est pas encore activé. Vous avez accès limité aux fonctionnalités suivantes :</p>
          <ul class="list-disc list-inside space-y-1 ml-2">
            <li>Consulter et acheter des <strong>licences</strong> pour activer votre compte</li>
            <li>Consulter et vous inscrire aux <strong>stages</strong></li>
            <li>Consulter et acheter <strong>inscriptions tournoi</strong> et <strong>équipements</strong></li>
            <li>Consulter les règles et informations</li>
          </ul>
          <p class="mt-3 font-medium">💡 Achetez votre licence ci-dessous pour débloquer toutes les fonctionnalités !</p>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div data-controller="tabs">
  <div class="mb-8 border-b border-gray-200">
    <nav class="flex flex-wrap gap-6" aria-label="Catégories boutique">
      <% categories = [
        ["credits", "Crédits", @credits_packs],
        ["licence", "Licence", @licence_packs],
        ["stage", "Stages", @stage_packs],
        ["tournament", "Tournois", @inscription_tournoi_packs.to_a],
        ["equipment", "Équipements", @equipements_packs.to_a]
      ] %>
      <% categories.each_with_index do |(key, label, packs), index| %>
        <% next if packs.blank? %>
        <button
          type="button"
          data-tabs-target="tab"
          data-action="click->tabs#switch"
          data-tab="<%= key %>"
          class="<%= index.zero? ? 'py-4 border-b-2 border-asmbv-red text-asmbv-red font-semibold uppercase tracking-wide text-sm' : 'py-4 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-semibold uppercase tracking-wide text-sm' %>"
        >
          <%= label %>
        </button>
      <% end %>
    </nav>
  </div>

<%# Packs de crédits %>
<% if @credits_packs.any? %>
  <div data-tabs-target="panel" data-panel="credits" class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
      <%= lucide_icon("coins", size: 24, class: "text-asmbv-red") %>
      Packs de crédits
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @credits_packs.each do |pack| %>
        <div class="bg-white rounded-none border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
          <%# Header épuré %>
          <div class="p-4 border-b border-gray-100">
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-lg font-semibold text-gray-900"><%= pack.name %></h3>
                <% if pack.description.present? %>
                  <p class="text-sm text-gray-600 mt-1"><%= pack.description %></p>
                <% end %>
              </div>
              <%= lucide_icon("coins", size: 24, class: "text-gray-400") %>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-2xl font-bold text-gray-900"><%= pack.amount_eur.to_i %></span>
              <span class="text-lg text-gray-600">€</span>
              <% if pack.amount_eur != pack.amount_eur.to_i %>
                <span class="text-sm text-gray-500"><%= sprintf("%.2f", pack.amount_eur).split('.')[1] %></span>
              <% end %>
            </div>
          </div>

          <%# Content %>
          <div class="flex-1 p-4 flex flex-col">
            <%# Crédits %>
            <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-100">
              <div class="flex items-center gap-2 text-gray-600">
                <%= lucide_icon("coins", size: 16, class: "text-gray-500") %>
                <span class="text-sm font-medium">Crédits</span>
              </div>
              <span class="text-lg font-bold text-gray-900"><%= pack.credits %></span>
            </div>

            <%# Taux de conversion %>
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-4">
              <%= lucide_icon("trending-up", size: 14, class: "text-green-600") %>
              <span><%= pack.credits_per_euro.round %> crédits/€</span>
              <% bonus = ((pack.credits.to_f / pack.amount_eur - 100) / 100 * 100).round %>
              <% if bonus > 0 %>
                <%= render BadgeComponent.new(label: "+#{bonus}%", variant: :warning, size: :xs) %>
              <% end %>
            </div>

            <%# Bouton d'achat %>
            <%= button_to buy_pack_path(pack),
                  method: :post,
                  class: "w-full inline-flex items-center justify-center gap-2 rounded-none bg-asmbv-red px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-asmbv-red transition-all mt-auto",
                  data: { turbo: false } do %>
              <%= lucide_icon("shopping-cart", size: 16) %>
              Acheter
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Packs de stage %>
<% if @stage_packs.any? %>
  <div data-tabs-target="panel" data-panel="stage" class="mb-12 hidden">
    <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
      <%= lucide_icon("calendar", size: 24, class: "text-blue-600") %>
      Stages disponibles
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <% @stage_packs.each do |pack| %>
        <div class="bg-white rounded-none border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
          <%# Header épuré %>
          <div class="p-4 border-b border-gray-100">
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-lg font-semibold text-gray-900"><%= pack.stage.title %></h3>
                <% if pack.stage.description.present? %>
                  <p class="text-sm text-gray-600 mt-1"><%= pack.stage.description %></p>
                <% end %>
              </div>
              <%= lucide_icon("calendar", size: 24, class: "text-gray-400") %>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-2xl font-bold text-gray-900"><%= pack.amount_eur.to_i %></span>
              <span class="text-lg text-gray-600">€</span>
              <% if pack.amount_eur != pack.amount_eur.to_i %>
                <span class="text-sm text-gray-500"><%= sprintf("%.2f", pack.amount_eur).split('.')[1] %></span>
              <% end %>
            </div>
          </div>

          <%# Content %>
          <div class="flex-1 p-4 flex flex-col">
            <%# Dates du stage %>
            <div class="flex items-center justify-between mb-3 pb-3 border-b border-gray-100">
              <div class="flex items-center gap-2 text-gray-600">
                <%= lucide_icon("calendar-days", size: 16, class: "text-gray-500") %>
                <span class="text-sm font-medium">Dates</span>
              </div>
              <span class="text-xs text-gray-500">
                <%= pack.stage.starts_on.strftime("%d/%m") %> - <%= pack.stage.ends_on.strftime("%d/%m") %>
              </span>
            </div>

            <%# Durée du stage %>
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-4">
              <%= lucide_icon("clock", size: 14, class: "text-gray-400") %>
              <span><%= (pack.stage.ends_on - pack.stage.starts_on + 1).to_i %> jour(s)</span>
            </div>

            <%# Boutons d'action %>
            <div class="flex flex-col gap-2 mt-auto">
              <%= link_to stage_path(pack.stage),
                    class: "w-full inline-flex items-center justify-center gap-2 rounded-none bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500 transition-all" do %>
                <%= lucide_icon("info", size: 16) %>
                Détails
              <% end %>
              
              <% if pack.stage.current_or_upcoming? %>
                <%= button_to buy_pack_path(pack),
                      method: :post,
                      class: "w-full inline-flex items-center justify-center gap-2 rounded-none bg-asmbv-red px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-asmbv-red transition-all",
                      data: { turbo: false } do %>
                  <%= lucide_icon("user-plus", size: 16) %>
                  S'inscrire
                <% end %>
              <% else %>
                <div class="w-full inline-flex items-center justify-center gap-2 rounded-none bg-gray-300 px-4 py-2 text-sm font-semibold text-gray-500 cursor-not-allowed">
                  <%= lucide_icon("calendar-x", size: 16) %>
                  Terminé
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Packs de licence %>
<% if @licence_packs.any? %>
