<%# Message si aucun pack ni stage %>
<% if @credits_packs.empty? && @licence_packs.empty? && @stage_packs.empty? && @inscription_tournoi_packs.to_a.empty? && @equipements_packs.to_a.empty? %>
  <div class="text-center py-16 bg-white rounded-none border border-gray-200 shadow-sm">
    <div class="flex flex-col items-center gap-4">
      <%= lucide_icon("package", size: 64, class: "text-gray-300") %>
      <div>
        <p class="text-xl font-semibold text-gray-900 mb-2">Aucun pack ou stage disponible</p>
