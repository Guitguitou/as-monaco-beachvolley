<div class="max-w-xl mx-auto">
  <div class="bg-white rounded-none border border-gray-200 shadow-sm p-6 sm:p-8">
    <p class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Boutique</p>
    <h1 class="font-bebas-neue text-3xl tracking-wider text-gray-900 mb-2 uppercase">Finaliser l'achat</h1>
    <p class="text-sm text-gray-600 mb-6">
      Pour vous donner l’accès et retrouver votre paiement, on a besoin de vos informations.
      Si vous n’avez pas encore de compte, il sera créé automatiquement et vous recevrez un email pour définir votre mot de passe.
    </p>

    <% if flash.now[:alert].present? %>
      <%= render BadgeComponent.new(label: flash.now[:alert], variant: :danger, size: :md) %>
    <% end %>

    <%= form_with url: buy_pack_path(@pack), method: :post, data: { turbo: false }, class: "space-y-4" do |f| %>
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: "guest[email]",
          type: :email_field,
          label: "Email",
          required: true,
          input_class: "block w-full rounded-none border border-gray-300 bg-white px-3 py-2 text-gray-900 focus:border-asmbv-red focus:ring-2 focus:ring-asmbv-red",
          html_options: { value: params.dig(:guest, :email), autocomplete: "email" }
        ) %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: "guest[first_name]",
            type: :text_field,
            label: "Prénom",
            required: true,
            input_class: "block w-full rounded-none border border-gray-300 bg-white px-3 py-2 text-gray-900 focus:border-asmbv-red focus:ring-2 focus:ring-asmbv-red",
            html_options: { value: params.dig(:guest, :first_name), autocomplete: "given-name" }
          ) %>
        </div>

        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: "guest[last_name]",
            type: :text_field,
            label: "Nom",
            required: true,
            input_class: "block w-full rounded-none border border-gray-300 bg-white px-3 py-2 text-gray-900 focus:border-asmbv-red focus:ring-2 focus:ring-asmbv-red",
            html_options: { value: params.dig(:guest, :last_name), autocomplete: "family-name" }
          ) %>
        </div>
      </div>

      <div class="pt-2 flex flex-col sm:flex-row gap-3">
        <%= f.submit "Continuer vers le paiement",
              class: "inline-flex items-center justify-center rounded-none bg-asmbv-red px-4 py-2 text-sm font-semibold text-white hover:bg-asmbv-red-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-asmbv-red transition-all" %>
        <%= button("Se connecter", variant: :ghost, size: :medium, href: new_user_session_path(email: params.dig(:guest, :email))) %>
        <%= button("Retour aux packs", variant: :secondary, size: :medium, href: packs_path) %>
      </div>
    <% end %>
  </div>
</div>

