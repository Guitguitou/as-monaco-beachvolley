<% content_for :page_title, "Informations" %>

<div class="max-w-7xl mx-auto">
  <p class="text-gray-600 text-base mb-8 max-w-xl">
    Toutes les informations utiles sur le club AS Monaco Beach-Volley.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0.5 bg-gray-200 rounded-none overflow-hidden border border-gray-200">
    <%= render "infos/info_tile",
          href: "https://docs.google.com/forms/d/e/1FAIpQLScoKZR2ATXZfDnIqLOnIP90tXB23wtBwsD2yiMSosqrQM6xWA/viewform?usp=sf_link",
          external: true,
          icon: "user-plus",
          icon_bg: "bg-asmbv-red",
          title: "Inscription",
          description: "Formulaire d'inscription à l'association." %>

    <%= render "infos/info_tile",
          href: packs_path,
          icon: "credit-card",
          icon_bg: "bg-asmbv-red",
          title: "Boutique",
          description: "Crédits, licences, inscriptions tournoi et équipements." %>

    <%= render "infos/info_tile",
          href: "https://chat.whatsapp.com/J05V2o3sPhdAwoPto5DiVo",
          external: true,
          icon: "message-circle",
          icon_bg: "bg-green-600",
          title: "Communauté WhatsApp",
          description: "Rejoignez le groupe WhatsApp de l'association." %>

    <%= render "infos/info_tile",
          href: infos_videos_path,
          icon: "play",
          icon_bg: "bg-asmbv-red",
          title: "Vidéos tutos",
          description: "Tutoriels et conseils techniques." %>

    <%= render "infos/info_tile",
          href: infos_planning_trainings_path,
          icon: "calendar",
          icon_bg: "bg-blue-700",
          title: "Planning entraînements",
          description: "Horaires des sessions régulières." %>

    <%= render "infos/info_tile",
          href: infos_planning_season_path,
          icon: "calendar",
          icon_bg: "bg-green-600",
          title: "Planning saison",
          description: "Calendrier de la saison." %>

    <%= render "infos/info_tile",
          href: infos_internal_rules_path,
          icon: "file-text",
          icon_bg: "bg-orange-600",
          title: "Règlement intérieur",
          description: "Règles et fonctionnement du club." %>

    <%= render "infos/info_tile",
          href: infos_reservations_leads_path,
          icon: "users",
          icon_bg: "bg-blue-800",
          title: "Responsables réservations",
          description: "Contacts et responsables par créneau." %>

    <%= render "infos/info_tile",
          href: infos_brochure_path,
          icon: "book-open",
          icon_bg: "bg-asmbv-red",
          title: "Plaquette",
          description: "Présentation du club." %>

    <%= render "infos/info_tile",
          href: infos_registration_rules_path,
          icon: "scale",
          icon_bg: "bg-gray-900",
          title: "Règles d'inscription",
          description: "Les règles de l'inscription." %>
  </div>
</div>
