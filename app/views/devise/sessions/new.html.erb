<div class="max-w-md mx-auto mt-16">
  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do |card| %>
    <% card.with_header do %>
      <h2 class="text-2xl font-bold text-center text-gray-900">Connexion</h2>
    <% end %>

  <%= form_with model: resource, 
              as: resource_name, 
              url: user_session_path, 
              local: true,
              html: { class: "space-y-6" } do |f| %>

    <% if flash.alert %>
      <%= render BadgeComponent.new(label: flash.alert, variant: :danger, size: :md) %>
    <% end %>

    <!-- Email -->
    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :email,
        type: :email_field,
        label: "Adresse email",
        required: true,
        html_options: { autofocus: true }
      ) %>
    </div>

    <!-- Mot de passe -->
    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :password,
        type: :password_field,
        label: "Mot de passe",
        required: true
      ) %>
    </div>

    <!-- Se souvenir de moi -->
    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, 
              class: "h-4 w-4 text-asmbv-red border-gray-300 rounded-none focus:ring-asmbv-red" %>
        <%= f.label :remember_me, "Se souvenir de moi", 
              class: "ml-2 block text-sm text-gray-700" %>
      </div>
    <% end %>

    <!-- Bouton connexion -->
    <div>
      <%= f.submit "Se connecter", 
            class: "w-full inline-flex justify-center items-center gap-2 rounded-none bg-asmbv-red px-4 py-2 
                    text-sm font-semibold text-white hover:bg-asmbv-red-dark 
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-asmbv-red transition-colors" %>
    </div>
  <% end %>

  <!-- Lien mot de passe oublié -->
  <div class="mt-4 text-center">
    <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), 
          class: "text-sm font-medium text-asmbv-red hover:text-asmbv-red-dark" %>
  </div>
  <% end %>
</div>
