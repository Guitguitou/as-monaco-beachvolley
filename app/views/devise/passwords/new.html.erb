<div class="max-w-md mx-auto mt-16">
  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do |card| %>
    <% card.with_header do %>
      <h2 class="text-2xl font-bold text-center text-gray-900">Mot de passe oublié</h2>
    <% end %>

  <%= form_with model: resource, 
              as: resource_name, 
              url: user_password_path, 
              local: true,
              html: { class: "space-y-6" } do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- Email -->
    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :email,
        type: :email_field,
        label: "Adresse email",
        required: true
      ) %>
    </div>

    <!-- Submit -->
    <div>
      <%= f.submit "Envoyer les instructions", 
            class: "w-full inline-flex justify-center items-center gap-2 rounded-none bg-asmbv-red px-4 py-2 
                    text-sm font-semibold text-white hover:bg-asmbv-red-dark 
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-asmbv-red transition-colors" %>
    </div>
  <% end %>
  <% end %>
</div>
