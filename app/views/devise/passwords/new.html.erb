<div class="max-w-md mx-auto mt-16 bg-white p-8 rounded-lg shadow-md">
  <h2 class="text-2xl font-bold text-center text-gray-900 mb-6">Mot de passe oublié</h2>

  <%= form_with model: resource, 
              as: resource_name, 
              url: user_password_path, 
              local: true,
              html: { class: "space-y-6" } do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <!-- Email -->
    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :email,
        type: :email_field,
        label: "Adresse email",
        required: true
      ) %>
    </div>

    <!-- Submit -->
    <div>
      <%= f.submit "Envoyer les instructions", 
            class: "w-full inline-flex justify-center items-center gap-x-1.5 rounded-md bg-asmbv-red px-4 py-2 
                    text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark 
                    focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 
                    focus-visible:outline-asmbv-red transition-colors" %>
    </div>
  <% end %>
</div>
