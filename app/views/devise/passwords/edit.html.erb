<div class="max-w-md mx-auto mt-16 bg-white p-8 rounded-lg shadow-md">
  <h2 class="text-2xl font-bold text-center text-gray-900 mb-6">Changer votre mot de passe</h2>

  <%= form_for(resource, as: resource_name, url: user_password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <!-- Nouveau mot de passe -->
    <div>
      <%= f.label :password, "Nouveau mot de passe", class: "block text-sm font-medium text-gray-900" %>
      <% if @minimum_password_length %>
        <p class="mt-1 text-sm text-gray-500">(<%= @minimum_password_length %> caractères minimum)</p>
      <% end %>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :password,
        type: :password_field,
        required: false,
        show_label: false,
        html_options: { autofocus: true, autocomplete: "new-password" }
      ) %>
    </div>

    <!-- Confirmation -->
    <div>
      <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "block text-sm font-medium text-gray-900" %>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :password_confirmation,
        type: :password_field,
        required: false,
        show_label: false,
        html_options: { autocomplete: "new-password" }
      ) %>
    </div>

    <!-- Bouton -->
    <div>
      <%= f.submit "Changer mon mot de passe", 
            class: "w-full inline-flex justify-center items-center gap-x-1.5 rounded-md bg-asmbv-red px-4 py-2 
                    text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark 
                    focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 
                    focus-visible:outline-asmbv-red transition-colors" %>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>
