<div class="max-w-md mx-auto mt-10">
  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do |card| %>
    <% card.with_header do %>
      <h2 class="text-2xl font-bold text-center text-gray-900">Créer un compte</h2>
    <% end %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :email,
        type: :email_field,
        label: "Adresse email",
        required: false,
        html_options: { autofocus: true, autocomplete: "email" }
      ) %>
    </div>

    <div>
      <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-900" %>
      <% if @minimum_password_length %>
        <p class="mt-1 text-xs text-gray-500">(<%= @minimum_password_length %> caractères minimum)</p>
      <% end %>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :password,
        type: :password_field,
        required: false,
        show_label: false,
        html_options: { autocomplete: "new-password" }
      ) %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmation du mot de passe", class: "block text-sm font-medium text-gray-900" %>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :password_confirmation,
        type: :password_field,
        required: false,
        show_label: false,
        html_options: { autocomplete: "new-password" }
      ) %>
    </div>

    <div>
      <%= f.submit "Créer mon compte",
            class: "w-full inline-flex justify-center items-center gap-2 rounded-none bg-asmbv-red px-4 py-2 text-sm font-semibold text-white hover:bg-asmbv-red-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-asmbv-red transition-colors" %>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <%= render "devise/shared/links" %>
  </div>
  <% end %>
</div>
