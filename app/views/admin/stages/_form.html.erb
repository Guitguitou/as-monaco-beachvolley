<%= form_with model: stage,
              url: stage.persisted? ? admin_stage_path(stage) : admin_stages_path,
              method: stage.persisted? ? :put : :post,
              class: "space-y-6 bg-white p-6 rounded-lg shadow-md max-w-3xl mx-auto" do |f| %>
  <%= render "shared/form_errors", object: stage %>

  <div class="grid grid-cols-1 gap-6">
    <div>
      <%= render FormFieldComponent.new(form: f, attribute: :title, type: :text_field, label: "Titre", required: true) %>
    </div>

    <div>
      <%= render FormFieldComponent.new(form: f, attribute: :description, type: :text_area, label: "Description", html_options: { rows: 4 }) %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :starts_on,
          type: :date_field,
          label: "Début"
        ) %>
      </div>
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :ends_on,
          type: :date_field,
          label: "Fin"
        ) %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :price,
          type: :number_field,
          label: "Prix (EUR)",
          required: false,
          html_options: { step: 0.01 }
        ) %>
      </div>
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :registration_link,
          type: :url_field,
          label: "Lien d'inscription",
          required: false,
          html_options: { placeholder: "https://..." }
        ) %>
      </div>
    </div>

    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :image,
        type: :file_field,
        label: "Image",
        required: false,
        input_class: "block w-full text-sm text-gray-900"
      ) %>
      <% if stage.image.attached? %>
        <div class="mt-2">
          <%= image_tag stage.image, class: "h-24 rounded-md" %>
        </div>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :main_coach_id,
          type: :select,
          label: "Coach principal",
          required: false,
          select_options: { include_blank: "—" },
          options: options_from_collection_for_select(
            User.coachs.order(:first_name, :last_name),
            :id,
            :full_name,
            stage.main_coach_id
          ),
          html_options: { class: "shadow-sm" }
        ) %>
      </div>
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :assistant_coach_id,
          type: :select,
          label: "Coach adjoint",
          required: false,
          select_options: { include_blank: "—" },
          options: options_from_collection_for_select(
            User.coachs.order(:first_name, :last_name),
            :id,
            :full_name,
            stage.assistant_coach_id
          ),
          html_options: { class: "shadow-sm" }
        ) %>
      </div>
    </div>
  </div>

  <div>
    <%= f.submit class: "w-full inline-flex justify-center items-center gap-x-1.5 rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-asmbv-red transition-colors" do %>
      <%= lucide_icon("save", size: 16) %> Enregistrer
    <% end %>
  </div>
<% end %>
