<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <!-- KPIs Cards -->
  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
  <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-blue-500 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">🏋️</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Entraînements (semaine)</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @kpis[:trainings_count] %></p>
      </div>
    </div>
  <% end %>

  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
  <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-green-500 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">🎮</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Jeux libres (semaine)</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @kpis[:free_plays_count] %></p>
      </div>
    </div>
  <% end %>

  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
  <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-purple-500 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">👥</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Coachings privés (semaine)</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @kpis[:private_coachings_count] %></p>
      </div>
    </div>
  <% end %>

  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
  <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-red-500 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">⚠️</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Désinscriptions hors délai</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @kpis[:late_cancellations_count] %></p>
      </div>
    </div>
  <% end %>
</div>

<!-- Inscrits par mois (jeu libre + entrainement) -->
<% stats_month_date = Date.new(@stats_year, @stats_month, 1) %>
<% prev_month = stats_month_date - 1.month %>
<% next_month = stats_month_date + 1.month %>
<% next_month_future = next_month > Date.current %>
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Inscrits par mois</h3>
    <nav class="flex items-center gap-2" aria-label="Navigation par mois">
      <%= button("Mois précédent", variant: :ghost, size: :small, href: admin_root_path(tab: "overview", stats_year: prev_month.year, stats_month: prev_month.month)) %>
      <span class="text-sm font-medium text-gray-700"><%= l(stats_month_date, format: :month_and_year) %></span>
      <% if next_month_future %>
        <%= button("Mois suivant", variant: :ghost, size: :small, href: admin_root_path(tab: "overview", stats_year: next_month.year, stats_month: next_month.month)) %>
      <% else %>
        <span class="text-sm text-gray-400">Mois suivant</span>
      <% end %>
    </nav>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-green-500 rounded-none flex items-center justify-center">
            <span class="text-white text-sm font-medium">🎮</span>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500">Inscrits en jeu libre (mois)</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @participants_jeu_libre %></p>
        </div>
      </div>
    <% end %>
    <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="w-8 h-8 bg-blue-500 rounded-none flex items-center justify-center">
            <span class="text-white text-sm font-medium">🏋️</span>
          </div>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-500">Inscrits en entrainement (mois)</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @participants_entrainement %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Financial KPIs -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-green-600 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">€</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">CA semaine (€)</p>
        <p class="text-2xl font-semibold text-gray-900"><%= number_to_currency(@kpis[:revenue], unit: "", separator: ",", delimiter: "") %></p>
      </div>
    </div>
  <% end %>

  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-orange-500 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">👥</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Salaires coachs (€)</p>
        <p class="text-2xl font-semibold text-gray-900"><%= number_to_currency(@kpis[:coach_salaries], unit: "", separator: ",", delimiter: "") %></p>
      </div>
    </div>
  <% end %>

  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do %>
    <div class="flex items-center">
      <div class="flex-shrink-0">
        <div class="w-8 h-8 bg-<%= @kpis[:net_profit] >= 0 ? 'green' : 'red' %>-500 rounded-none flex items-center justify-center">
          <span class="text-white text-sm font-medium">📊</span>
        </div>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Différence (€)</p>
        <p class="text-2xl font-semibold text-gray-900"><%= number_to_currency(@kpis[:net_profit], unit: "", separator: ",", delimiter: "") %></p>
      </div>
    </div>
  <% end %>
</div>

<!-- Upcoming Sessions -->
<%= render CardComponent.new(padding: :none, class_name: "border border-gray-200") do |card| %>
  <% card.with_header do %>
    <div class="px-6 py-4 border-b border-gray-200">
      <h3 class="text-lg font-medium text-gray-900">Sessions à venir</h3>
    </div>
  <% end %>
  <div class="p-6">
    <% if @upcoming_sessions.any? %>
      <div class="space-y-4">
        <% @upcoming_sessions.each do |session_type, sessions| %>
          <div>
            <h4 class="text-md font-medium text-gray-700 mb-2">
              <%= case session_type.to_s
                  when 'entrainement' then 'Entraînements à venir'
                  when 'jeu_libre' then 'Jeux libres à venir'
                  when 'coaching_prive' then 'Coachings privés à venir'
                  else session_type.to_s.humanize
                  end %>
            </h4>
            <div class="space-y-2">
              <% sessions.each do |session| %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-none border border-gray-100">
                  <div>
                    <p class="font-medium text-gray-900"><%= session.title %></p>
                    <p class="text-sm text-gray-500">
                      <%= session.start_at.strftime("%d/%m - %H:%M") %> - <%= session.terrain %>
                    </p>
                  </div>
                  <div class="text-right">
                    <p class="text-sm text-gray-500">
                      <%= session.registrations.confirmed.count %>/<%= session.max_players || '∞' %> places
                    </p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-4">Aucune session à venir</p>
    <% end %>
  </div>
<% end %>
