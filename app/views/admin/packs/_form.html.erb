<%= form_with model: [:admin, pack],
              class: "space-y-6 bg-white p-6 rounded-lg shadow-md max-w-3xl mx-auto" do |f| %>
  
  <%= render "shared/form_errors", object: pack %>

  <div class="grid grid-cols-1 gap-6" data-controller="pack-type-selector">
    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :name,
        type: :text_field,
        label: "Nom du pack",
        required: true,
        html_options: { placeholder: "Ex: Pack Premium" }
      ) %>
    </div>

    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :description,
        type: :text_area,
        label: "Description",
        html_options: { rows: 4, placeholder: "Décrivez les avantages de ce pack..." }
      ) %>
    </div>

    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :pack_type,
        type: :select,
        label: "Type de pack",
        required: false,
        select_options: { include_blank: false },
        options: Pack.pack_types.keys.map { |k| [k.humanize, k] },
        html_options: {
          class: "shadow-sm",
          data: {
            pack_type_selector_target: "select",
            action: "change->pack-type-selector#change"
          }
        }
      ) %>
      <% unless pack.errors[:pack_type].any? %>
        <p class="mt-1 text-xs text-gray-500">Sélectionnez le type de pack</p>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :amount_cents,
          type: :number_field,
          label: "Montant (centimes)",
          required: true,
          html_options: { placeholder: "1000" }
        ) %>
        <% unless pack.errors[:amount_cents].any? %>
          <p class="mt-1 text-xs text-gray-500">1000 centimes = 10 EUR</p>
        <% end %>
      </div>

      <div>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :credits,
          type: :number_field,
          label: "Nombre de crédits",
          required: false,
          html_options: {
            placeholder: "1000",
            data: { pack_type_selector_target: "creditsField" }
          }
        ) %>
        <% unless pack.errors[:credits].any? %>
          <p class="mt-1 text-xs text-gray-500">Requis pour les packs de crédits</p>
        <% end %>
      </div>
    </div>

    <div data-pack-type-selector-target="stageField" style="display: none;">
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :stage_id,
        type: :select,
        label: "Stage associé",
        required: false,
        select_options: { prompt: "Sélectionnez un stage" },
        options: options_from_collection_for_select(@stages, :id, :title, @pack.stage_id),
        html_options: {
          class: "shadow-sm",
          data: { pack_type_selector_target: "stageSelect" }
        }
      ) %>
      <% unless pack.errors[:stage_id].any? %>
        <p class="mt-1 text-xs text-gray-500">Requis pour les packs de stage</p>
      <% end %>
    </div>

    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :position,
        type: :number_field,
        label: "Position (ordre d'affichage)",
        required: false,
        html_options: { placeholder: "1" }
      ) %>
      <% unless pack.errors[:position].any? %>
        <p class="mt-1 text-xs text-gray-500">Les packs avec position plus petite s'affichent en premier</p>
      <% end %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :active, class: "rounded border-gray-300 text-asmbv-red focus:ring-asmbv-red" %>
      <%= f.label :active, "Pack actif (visible pour les utilisateurs)", class: "text-sm font-medium text-gray-900" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :public, class: "rounded border-gray-300 text-asmbv-red focus:ring-asmbv-red" %>
      <%= f.label :public, "Accessible hors connexion (visible et achetable sans se connecter)", class: "text-sm font-medium text-gray-900" %>
    </div>
    <p class="text-xs text-gray-500">Par défaut, un pack n’est visible et achetable que pour les utilisateurs connectés.</p>
  </div>

  <div>
    <%= f.submit class: "w-full inline-flex justify-center items-center gap-x-1.5 rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-asmbv-red transition-colors" do %>
      <%= lucide_icon("save", size: 16) %> Enregistrer
    <% end %>
  </div>
<% end %>
