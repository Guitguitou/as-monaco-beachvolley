<div class="flex items-center justify-between mb-6 flex-col gap-3 sm:flex-row sm:gap-0">
  <h1 class="text-2xl font-bold flex items-center gap-2 text-gray-900">
    <%= lucide_icon("calendar-clock") %>
    Sessions
  </h1>

  <% if can?(:create, Session) %>
  <%= button("Nouvelle session", variant: :primary, size: :medium, href: new_admin_session_path) %>
  <% end %>
</div>

<div class="overflow-x-auto rounded-none border border-gray-200 shadow-sm">
  <table class="min-w-full divide-y divide-gray-200 bg-white text-sm table-fixed">
    <thead class="bg-gray-50 text-gray-600 uppercase text-xs tracking-wide">
      <tr>
        <th class="px-4 sm:px-6 py-3 text-left w-2/5">Titre</th>
        <th class="px-4 sm:px-6 py-3 text-left hidden md:table-cell w-1/6">Type</th>
        <th class="px-4 sm:px-6 py-3 text-left hidden lg:table-cell w-1/12">Terrain</th>
        <th class="px-4 sm:px-6 py-3 text-left hidden lg:table-cell w-1/6">Niveau</th>
        <th class="px-4 sm:px-6 py-3 text-left w-1/5">Date</th>
        <th class="px-4 sm:px-6 py-3 text-left hidden md:table-cell w-1/6">Coach / Responsable</th>
        <th class="px-4 sm:px-6 py-3 text-right w-16 sm:w-24">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @sessions.each do |session| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <!-- Titre -->
          <td class="px-4 sm:px-6 py-4 whitespace-nowrap font-medium text-gray-800 flex items-center gap-2">
            <%= lucide_icon("calendar", size: 16, class: "text-gray-500") %>
            <%= session.title.presence || "(Sans titre)" %>
          </td>

          <!-- Type -->
          <td class="px-4 sm:px-6 py-4 text-gray-700 hidden md:table-cell">
            <% case session.session_type %>
            <% when "entrainement" %>
              <%= render BadgeComponent.new(label: "Entraînement", variant: :type_training, size: :xs) %>
            <% when "coaching_prive" %>
              <%= render BadgeComponent.new(label: "Coaching privé", variant: :type_private, size: :xs) %>
            <% when "jeu_libre" %>
              <%= render BadgeComponent.new(label: "Jeu libre", variant: :type_free_play, size: :xs) %>
            <% when "tournoi" %>
              <%= render BadgeComponent.new(label: "Tournoi", variant: :type_tournament, size: :xs) %>
            <% end %>
          </td>

          <!-- Terrain -->
          <td class="px-4 sm:px-6 py-4 text-gray-700 hidden lg:table-cell">
            <%= render BadgeComponent.new(label: session.terrain.to_s.split('_').last, variant: :neutral, size: :xs) %>
          </td>

          <!-- Niveaux -->
          <td class="px-4 sm:px-6 py-4 text-gray-700 space-x-1 hidden lg:table-cell">
            <% session.levels.each do |level| %>
              <%= render BadgeComponent.new(label: level.name, variant: :neutral, size: :xs) %>
            <% end %>
          </td>

          <!-- Date -->
          <td class="px-4 sm:px-6 py-4 text-gray-700">
            <%= l session.start_at, format: :short %> — <%= l session.end_at, format: :short %>
          </td>

          <!-- Organisateur -->
          <td class="px-4 sm:px-6 py-4 text-gray-700 hidden md:table-cell">
            <%= session.user&.full_name || "-" %>
          </td>

          <!-- Actions -->
          <td class="px-4 sm:px-6 py-4 text-right space-x-2">
            <%= link_to admin_session_path(session),
                  class: "inline-flex items-center gap-1 text-sm text-gray-600 hover:text-asmbv-red transition-colors" do %>
              <%= lucide_icon("eye", size: 16) %>
            <% end %>

            <%= link_to edit_admin_session_path(session),
                  class: "inline-flex items-center gap-1 text-sm text-gray-600 hover:text-asmbv-red-dark transition-colors" do %>
              <%= lucide_icon("edit", size: 16) %>
            <% end %>

            <%= link_to admin_session_path(session),
                  data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr de vouloir supprimer cette session ?" },
                  class: "inline-flex items-center gap-1 text-sm text-gray-600 hover:text-red-600 transition-colors" do %>
              <%= lucide_icon("trash", size: 16) %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
