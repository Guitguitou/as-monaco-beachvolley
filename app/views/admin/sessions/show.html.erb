<div class="max-w-5xl mx-auto space-y-8">
  <!-- Header -->
  <div class="flex items-center justify-between border-b pb-4">
    <div class="flex items-center gap-2">
      <%= lucide_icon("calendar", class: "w-6 h-6 text-asmbv-red") %>
      <h1 class="text-2xl font-bold text-gray-900"><%= @session.title.presence || "(Sans titre)" %></h1>
    </div>
    <div class="flex gap-2 items-center">
      <%= form_with url: duplicate_admin_session_path(@session), method: :post, local: true, class: "flex items-center gap-2" do |f| %>
        <label class="text-sm text-gray-700">Répéter (semaines):</label>
        <%= render FormFieldComponent.new(
          form: f,
          attribute: :weeks,
          type: :number_field,
          required: true,
          show_label: false,
          input_class: "w-20 border rounded px-2 py-1",
          html_options: { value: 3, min: 1, max: 20 }
        ) %>
        <%= button_tag type: :submit, class: "inline-flex items-center gap-1 rounded-none px-3 py-1.5 text-sm font-semibold text-white bg-gray-800 hover:bg-gray-700" do %>
          <%= lucide_icon("copy", size: 16) %>
          Dupliquer
        <% end %>
      <% end %>
      <%= link_to edit_admin_session_path(@session),
            class: "inline-flex items-center gap-1 rounded-none border border-gray-300 bg-white px-3 py-1.5 text-sm font-semibold text-gray-700 hover:bg-gray-50" do %>
        <%= lucide_icon("edit", size: 16) %> Modifier
      <% end %>
      <%= link_to admin_session_path(@session),
            data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr de vouloir supprimer cette session ?" },
            class: "inline-flex items-center gap-1 rounded-none border border-red-200 bg-red-50 px-3 py-1.5 text-sm font-semibold text-red-700 hover:bg-red-100" do %>
        <%= lucide_icon("trash", size: 16) %> Supprimer
      <% end %>
    </div>
  </div>

  <!-- Infos principales -->
  <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do |card| %>
    <% card.with_header do %>
      <h2 class="text-lg font-semibold text-gray-800">Informations de la session</h2>
    <% end %>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <dt class="text-sm font-medium text-gray-500">Type</dt>
        <dd class="mt-1">
          <% case @session.session_type %>
          <% when "entrainement" %>
            <%= render BadgeComponent.new(label: "Entraînement", variant: :type_training, size: :xs) %>
          <% when "coaching_prive" %>
            <%= render BadgeComponent.new(label: "Coaching privé", variant: :type_private, size: :xs) %>
          <% when "jeu_libre" %>
            <%= render BadgeComponent.new(label: "Jeu libre", variant: :type_free_play, size: :xs) %>
          <% when "tournoi" %>
            <%= render BadgeComponent.new(label: "Tournoi", variant: :type_tournament, size: :xs) %>
          <% end %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Terrain</dt>
        <dd class="mt-1">
          <%= render BadgeComponent.new(label: @session.terrain.to_s.split('_').last, variant: :neutral, size: :xs) %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Date</dt>
        <dd class="mt-1 text-gray-900"><%= l @session.start_at %> → <%= l @session.end_at, format: :time %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Max joueurs</dt>
        <dd class="mt-1 text-gray-900"><%= @session.max_players || "–" %></dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-500">Prix (crédits)</dt>
        <dd class="mt-1 text-gray-900"><%= @session.price.to_i %></dd>
      </div>

      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-gray-500">Coach / Responsable</dt>
        <dd class="mt-1 text-gray-900"><%= @session.user&.full_name || "–" %></dd>
      </div>

      <div class="sm:col-span-2">
        <dt class="text-sm font-medium text-gray-500">Niveaux</dt>
        <dd class="mt-1 flex flex-wrap gap-2">
          <% if @session.levels.any? %>
            <% @session.levels.each do |level| %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold"
                    style="background-color: <%= level.color %>22; color: <%= level.color %>;">
                <%= level.name %>
              </span>
            <% end %>
          <% else %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-100 text-gray-800 text-xs font-semibold">
              Tous niveaux
            </span>
          <% end %>
        </dd>
      </div>
    </dl>
  <% end %>

  <!-- Description -->
  <% if @session.description.present? %>
    <%= render CardComponent.new(padding: :lg, class_name: "border border-gray-200") do |card| %>
      <% card.with_header do %>
        <h2 class="text-lg font-semibold text-gray-800">Description</h2>
      <% end %>
      <p class="text-gray-700 whitespace-pre-line"><%= @session.description %></p>
    <% end %>
  <% end %>

  <!-- Retour -->
  <div>
    <%= link_to "← Retour aux sessions",
          admin_sessions_path,
          class: "text-sm font-medium text-asmbv-red hover:text-asmbv-red-dark" %>
  </div>
</div>
