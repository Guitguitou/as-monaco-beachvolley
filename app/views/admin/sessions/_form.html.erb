<%# Inline errors under fields + global block for :base and summary %>

<%= form_with model: session, 
              url: session.persisted? ? admin_session_path(session) : admin_sessions_path, 
              method: session.persisted? ? :put : :post, 
              data: {
                controller: "session-form",
                session_form_prices_value: Session::PRICE_BY_TYPE,
                session_form_terrain_closures_value: terrain_closures_json_for_forms
              },
               class: "space-y-6 bg-white p-6 rounded-lg shadow-md max-w-3xl mx-auto" do |f| %>

  <%= render "shared/form_errors", object: session %>

  <!-- Titre -->
  <div>
    <%= render FormFieldComponent.new(form: f, attribute: :title, type: :text_field, label: "Titre", required: true) %>
  </div>

  <!-- Description -->
  <div>
    <%= render FormFieldComponent.new(form: f, attribute: :description, type: :text_area, label: "Description", html_options: { rows: 3 }) %>
  </div>

  <!-- Notes entraîneur (entrainement uniquement, privé coach/admin) -->
  <div>
    <%= render FormFieldComponent.new(form: f, attribute: :coach_notes, type: :text_area, label: "Notes entraîneur (privé)", html_options: { rows: 4 }) %>
    <p class="text-xs text-gray-500 mt-1">Visible uniquement par les coachs et les admins. Utilisez-le pour le thème, les retours, etc.</p>
  </div>

  <!-- Type de session -->
  <div>
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :session_type,
      type: :select,
      label: "Type de session",
      required: false,
      select_options: { include_blank: false },
      options: options_for_select(Session.session_types.keys.map { |t| [t.humanize, t] }, session.session_type),
      html_options: { data: { session_form_target: "type", action: "session-form#onTypeChange" } }
    ) %>
  </div>

  <!-- Terrain -->
  <div>
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :terrain,
      type: :select,
      label: "Terrain",
      required: false,
      select_options: { include_blank: false },
      options: options_for_select(Session.terrains.keys.map { |t| ["Terrain #{t.to_s.split('_').last}", t] }, session.terrain),
      html_options: { data: { session_form_target: "terrain" } }
    ) %>
    <p class="mt-1 text-sm text-amber-700 hidden" data-session-form-target="terrainWarning">Terrain indisponible à cette date.</p>
  </div>

  <!-- Option admin: créer sur les 3 terrains -->
  <div class="flex items-start gap-2">
    <%= check_box_tag 'session[create_on_all_terrains]', '1', false, id: 'session_create_on_all_terrains', class: "mt-1 h-4 w-4 text-asmbv-red border-gray-300 rounded focus:ring-asmbv-red" %>
    <div>
      <label for="session_create_on_all_terrains" class="text-sm font-medium text-gray-900">Créer la même session sur les 3 terrains</label>
      <p class="text-xs text-gray-500">Cree 3 sessions identiques, une par terrain (1, 2 et 3).</p>
    </div>
  </div>

  <!-- Coach / Responsable / Organisateur -->
  <div class="hidden" data-session-form-target="userGroupCoach">
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :user_id,
      type: :select,
      label: "Coach",
      required: false,
      select_options: { include_blank: false },
      options: options_from_collection_for_select(User.coachs, :id, :full_name, session.user_id)
    ) %>
  </div>

  <div class="hidden" data-session-form-target="userGroupResponsable">
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :user_id,
      type: :select,
      label: "Responsable",
      required: false,
      select_options: { include_blank: false },
      options: options_from_collection_for_select(User.responsables, :id, :full_name, session.user_id)
    ) %>
  </div>

  <div class="hidden" data-session-form-target="userGroupAll">
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :user_id,
      type: :select,
      label: "Organisateur",
      required: false,
      select_options: { include_blank: false },
      options: options_from_collection_for_select(User.all, :id, :full_name, session.user_id)
    ) %>
  </div>

  <!-- Dates -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :start_at,
        type: :datetime_local_field,
        label: "Début",
        required: false,
        html_options: {
          step: 900,
          data: {
            session_form_target: "startAt",
            action: "change->session-form#onStartChange input->session-form#onStartChange blur->session-form#onStartChange"
          }
        }
      ) %>
    </div>

    <div>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :end_at,
        type: :datetime_local_field,
        label: "Fin",
        required: false,
        html_options: {
          step: 900,
          data: { session_form_target: "endAt", action: "input->session-form#onEndChange change->session-form#onEndChange" }
        }
      ) %>
      <%= hidden_field_tag "session[end_at]", session.end_at&.strftime('%Y-%m-%dT%H:%M'), data: { session_form_target: "endAtHidden" } %>
    </div>
  </div>

  <!-- Ouverture des inscriptions (entraîne­ment uniquement) -->
  <div>
    <%# Affiché seulement si type = entrainement %>
    <div class="mt-4" data-session-form-target="registrationOpensWrapper" <%= session.session_type == 'entrainement' ? '' : 'style="display:none"' %>>
      <%= render FormFieldComponent.new(
        form: f,
        attribute: :registration_opens_at,
        type: :datetime_local_field,
        label: "Ouverture des inscriptions",
        required: false,
        html_options: { step: 900 }
      ) %>
      <p class="text-xs text-gray-500 mt-1">Par défaut: 7 jours avant le début. Priorité compétition pendant 24h après l’ouverture.</p>
    </div>
  </div>

  <!-- Deadline de désinscription (optionnel, défaut midi le jour J pour entraînements) -->
  <div>
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :cancellation_deadline_at,
      type: :datetime_local_field,
      label: "Date limite de désinscription",
      required: false
    ) %>
    <p class="text-xs text-gray-500 mt-1">Après cette date/heure, la désinscription ne rembourse pas automatiquement.</p>
  </div>

  <!-- Nombre de joueurs -->
  <div>
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :max_players,
      type: :number_field,
      label: "Nombre maximum de joueurs",
      required: false
    ) %>
  </div>

  <!-- Prix (crédits) -->
  <div>
    <%= render FormFieldComponent.new(
      form: f,
      attribute: :price,
      type: :number_field,
      label: "Prix (crédits)",
      input_class: "block w-full rounded-md border border-gray-300 bg-gray-100 px-3 py-2 text-gray-900 focus:border-asmbv-red focus:ring-2 focus:ring-asmbv-red sm:text-sm",
      html_options: { min: 0, step: 1, readonly: true, data: { session_form_target: "price" } }
    ) %>
  </div>

  <!-- Niveaux -->
  <div>
    <%= f.label :level_ids, "Niveaux", class: "block text-sm font-medium text-gray-900 mb-2" %>
    <div class="flex flex-col gap-2">
      <%= f.collection_check_boxes :level_ids, (@levels || Level.all), :id, :name do |b| %>
        <label class="flex items-center gap-2">
          <%= b.check_box(class: "h-4 w-4 text-asmbv-red border-gray-300 rounded focus:ring-asmbv-red") %>
          <span class="text-sm text-gray-700"><%= "#{b.object.name} - #{b.object.gender.humanize}" %></span>
        </label>
      <% end %>
    </div>
    <% if session.errors[:level_ids].any? %>
      <p class="mt-1 text-sm text-red-600"><%= session.errors[:level_ids].first %></p>
    <% end %>
  </div>

  <!-- Bouton -->
  <div>
    <%= f.submit class: "w-full inline-flex justify-center items-center gap-x-1.5 rounded-md bg-asmbv-red px-4 py-2 
                        text-sm font-semibold text-white shadow-sm hover:bg-asmbv-red-dark 
                        focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 
                        focus-visible:outline-asmbv-red transition-colors" do %>
      <%= lucide_icon("save", size: 16) %> Enregistrer
    <% end %>
  </div>
<% end %>
