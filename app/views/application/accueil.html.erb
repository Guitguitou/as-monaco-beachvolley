<div class="bg-white">
  <% stage = @next_stage %>

  <section class="relative flex min-h-screen flex-col overflow-hidden bg-black text-white">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= asset_path('beach-volley-monaco.webp') %>');"></div>
    <div class="absolute inset-0 bg-black/55"></div>

    <% if stage %>
      <div class="relative z-20 border-b border-white/15 bg-black/50">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
          <p class="text-xs font-semibold uppercase tracking-wider text-white/90 sm:text-sm">
            Prochain stage - <%= stage.title %> · <%= l(stage.starts_on, format: :default) %> au <%= l(stage.ends_on, format: :default) %>
          </p>
          <%= link_to "En savoir plus", stage_path(stage), class: "inline-flex items-center border border-white/70 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-white transition hover:bg-white hover:text-black" %>
        </div>
      </div>
    <% end %>

    <div class="relative z-10 mx-auto flex w-full max-w-7xl flex-1 px-4 sm:px-6 lg:px-8">
      <div class="w-full pt-24 pb-20 sm:pt-28 sm:pb-24 lg:pt-36 lg:pb-32">
        <div class="inline-flex items-center bg-asmbv-red px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-white">
          Saison 2026 - Inscriptions ouvertes
        </div>

        <h1 class="mt-6 font-anton text-6xl uppercase leading-[0.9] text-white sm:text-7xl lg:text-8xl">
          Monaco
          <span class="block text-asmbv-red">Beach</span>
          <span class="block">Volley</span>
        </h1>

        <p class="mt-6 max-w-xl text-base text-white/90 sm:text-lg">
          Le club de reference a Monaco. Entrainements, stages et competitions pour tous les niveaux.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <% if user_signed_in? %>
            <%= link_to "Mon espace", performances_path, class: "inline-flex items-center bg-asmbv-red px-6 py-3 text-sm font-semibold uppercase tracking-wider text-white transition hover:bg-asmbv-red-dark" %>
          <% else %>
            <%= link_to "Rejoindre le club", new_user_registration_path, class: "inline-flex items-center bg-asmbv-red px-6 py-3 text-sm font-semibold uppercase tracking-wider text-white transition hover:bg-asmbv-red-dark" %>
          <% end %>
          <%= link_to "Voir les sessions", sessions_path, class: "inline-flex items-center border border-white/50 px-6 py-3 text-sm font-semibold uppercase tracking-wider text-white transition hover:bg-white hover:text-black" %>
        </div>
      </div>
    </div>

    <div class="relative z-10 mt-auto border-t border-white/15 bg-black/70">
      <div class="mx-auto grid max-w-7xl grid-cols-3 px-4 py-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <p class="font-anton text-3xl leading-none text-asmbv-red sm:text-4xl"><%= @members_count %></p>
          <p class="mt-1 text-[10px] font-semibold uppercase tracking-[0.24em] text-white/70 sm:text-xs">Membres</p>
        </div>
        <div class="text-center">
          <p class="font-anton text-3xl leading-none text-asmbv-red sm:text-4xl"><%= @terrains_count %></p>
          <p class="mt-1 text-[10px] font-semibold uppercase tracking-[0.24em] text-white/70 sm:text-xs">Terrains</p>
        </div>
        <div class="text-center">
          <p class="font-anton text-3xl leading-none text-asmbv-red sm:text-4xl"><%= @sessions_per_month %></p>
          <p class="mt-1 text-[10px] font-semibold uppercase tracking-[0.24em] text-white/70 sm:text-xs">Sessions/mois</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#f3f3f3] py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 sm:mb-10">
        <p class="text-[10px] font-semibold uppercase tracking-[0.24em] text-gray-600">Nos activites</p>
        <h2 class="mt-2 font-bebas-neue text-5xl uppercase leading-none text-gray-900 sm:text-6xl">Decouvrez le club</h2>
      </div>

      <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
        <%= link_to sessions_path, class: "relative min-h-[340px] overflow-hidden lg:col-span-2" do %>
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= asset_path('beach-volley-monaco.webp') %>');"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="inline-flex bg-asmbv-red px-2 py-1 text-[10px] font-semibold uppercase tracking-wider text-white">Sessions</span>
            <h3 class="mt-3 font-bebas-neue text-4xl uppercase leading-none text-white">Entrainements & jeu libre</h3>
            <p class="mt-3 text-sm text-white/85">Voir le calendrier</p>
          </div>
        <% end %>

        <div class="grid grid-rows-3 gap-4">
          <%= link_to stages_path, class: "relative min-h-[105px] overflow-hidden" do %>
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= asset_path('beach-volley-monaco.webp') %>');"></div>
            <div class="absolute inset-0 bg-black/45"></div>
            <div class="absolute inset-0 p-4">
              <span class="inline-flex bg-blue-600 px-2 py-1 text-[10px] font-semibold uppercase tracking-wider text-white">Stages</span>
              <p class="mt-3 font-bebas-neue text-3xl uppercase leading-none text-white">Stages intensifs</p>
            </div>
          <% end %>

          <%= link_to packs_path, class: "relative min-h-[105px] overflow-hidden" do %>
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= asset_path('beach-volley-monaco.webp') %>');"></div>
            <div class="absolute inset-0 bg-black/45"></div>
            <div class="absolute inset-0 p-4">
              <span class="inline-flex bg-green-600 px-2 py-1 text-[10px] font-semibold uppercase tracking-wider text-white">Boutique</span>
              <p class="mt-3 font-bebas-neue text-3xl uppercase leading-none text-white">Packs & credits</p>
            </div>
          <% end %>

          <%= link_to infos_root_path, class: "relative min-h-[105px] bg-asmbv-red p-4 text-white transition hover:bg-asmbv-red-dark" do %>
            <span class="inline-flex bg-black/20 px-2 py-1 text-[10px] font-semibold uppercase tracking-wider">Infos</span>
            <p class="mt-4 font-bebas-neue text-3xl uppercase leading-none">Informations</p>
            <p class="mt-2 text-xs uppercase tracking-wide text-white/90">Reglement, horaires, tarifs</p>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#f3f3f3] pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 sm:mb-10">
        <p class="text-[10px] font-semibold uppercase tracking-[0.24em] text-gray-600">Level up</p>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        <article class="border border-gray-200 bg-white p-6">
          <div class="h-8 w-8 bg-asmbv-red text-white flex items-center justify-center text-sm font-bold">1</div>
          <h3 class="mt-4 font-bebas-neue text-3xl uppercase leading-none text-gray-900">Debutant</h3>
          <p class="mt-3 text-sm text-gray-600">Decouvrez le beach-volley et apprenez les fondamentaux avec nos coachs.</p>
          <div class="mt-5 h-1 w-full bg-gray-200"><div class="h-full w-1/3 bg-asmbv-red"></div></div>
        </article>

        <article class="border border-gray-200 bg-white p-6">
          <div class="h-8 w-8 bg-blue-600 text-white flex items-center justify-center text-sm font-bold">2</div>
          <h3 class="mt-4 font-bebas-neue text-3xl uppercase leading-none text-gray-900">Intermediaire</h3>
          <p class="mt-3 text-sm text-gray-600">Perfectionnez votre technique et commencez la competition locale.</p>
          <div class="mt-5 h-1 w-full bg-gray-200"><div class="h-full w-2/3 bg-blue-600"></div></div>
        </article>

        <article class="border border-gray-200 bg-white p-6">
          <div class="h-8 w-8 bg-amber-500 text-white flex items-center justify-center text-sm font-bold">3</div>
          <h3 class="mt-4 font-bebas-neue text-3xl uppercase leading-none text-gray-900">Avance</h3>
          <p class="mt-3 text-sm text-gray-600">Atteignez le plus haut niveau et participez aux competitions regionales.</p>
          <div class="mt-5 h-1 w-full bg-gray-200"><div class="h-full w-full bg-amber-500"></div></div>
        </article>
      </div>
    </div>
  </section>
</div>
