<div class="space-y-6">
  <!-- À venir -->
  <%= render CardComponent.new(padding: :md) do |card| %>
    <% card.with_header do %>
      <h2 class="text-lg font-semibold text-gray-800">À venir</h2>
    <% end %>
    <% if @upcoming.any? %>
      <ul class="divide-y divide-gray-100">
        <% @upcoming.each do |session| %>
          <li class="py-3 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 text-gray-900 font-medium">
                <%= lucide_icon("calendar", class: "w-4 h-4 text-gray-500") %>
                <%= link_to (session.title.presence || session.display_name), me_session_path(session), class: "hover:text-asmbv-red" %>
              </div>
              <div class="mt-1 text-sm text-gray-600 flex items-center gap-2 flex-wrap">
                <%= render BadgeComponent.new(label: session.terrain.to_s.split('_').last, variant: :neutral, size: :xs) %>
                <%= render BadgeComponent.new(label: session.levels.map(&:name).join(', '), variant: :neutral, size: :xs) %>
                <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                  <%= lucide_icon("clock", class: "w-3 h-3") %>
                  <%= l session.start_at, format: :default %> — <%= l session.end_at, format: :time %>
                </span>
              </div>
            </div>
            <div class="text-right text-sm text-gray-600">
              <div class="font-semibold"><%= session.user&.full_name || "Organisateur" %></div>
              <div><%= session.price.to_i %> crédits</div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">Aucune session à venir.</p>
    <% end %>
  <% end %>

  <!-- Passées -->
  <%= render CardComponent.new(padding: :md) do |card| %>
    <% card.with_header do %>
      <h2 class="text-lg font-semibold text-gray-800">Passées</h2>
    <% end %>
    <% if @past.any? %>
      <ul class="divide-y divide-gray-100">
        <% @past.each do |session| %>
          <li class="py-3 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 text-gray-900 font-medium">
                <%= lucide_icon("calendar-check", class: "w-4 h-4 text-gray-500") %>
                <%= link_to (session.title.presence || session.display_name), me_session_path(session), class: "hover:text-asmbv-red" %>
              </div>
              <div class="mt-1 text-sm text-gray-600 flex items-center gap-2 flex-wrap">
                <%= render BadgeComponent.new(label: session.terrain.to_s.split('_').last, variant: :neutral, size: :xs) %>
                <%= render BadgeComponent.new(label: session.levels.map(&:name).join(', '), variant: :neutral, size: :xs) %>
                <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                  <%= lucide_icon("clock", class: "w-3 h-3") %>
                  <%= l session.start_at, format: :default %> — <%= l session.end_at, format: :time %>
                </span>
              </div>
            </div>
            <div class="text-right text-sm text-gray-600">
              <div class="font-semibold"><%= session.user&.full_name || "Organisateur" %></div>
              <div><%= session.price.to_i %> crédits</div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">Aucune session passée.</p>
    <% end %>
  <% end %>
</div>
