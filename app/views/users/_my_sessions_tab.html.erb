<div class="space-y-6">

  <!-- À venir -->
  <%= render CardComponent.new(padding: :none) do %>
    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">
      <span class="text-asmbv-red"><%= lucide_icon("calendar-clock", size: 18) %></span>
      <h2 class="text-sm font-bold text-gray-800 uppercase tracking-widest">À venir</h2>
      <% if @upcoming.any? %>
        <span class="text-[10px] font-bold px-1.5 py-0.5 bg-asmbv-red text-white rounded-full leading-none"><%= @upcoming.count %></span>
      <% end %>
    </div>

    <% if @upcoming.any? %>
      <ul class="divide-y divide-gray-100">
        <% @upcoming.each do |session| %>
          <li class="px-5 py-4 flex items-start justify-between gap-4 hover:bg-gray-50/60 transition-colors">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 text-gray-900 font-semibold">
                <%= link_to (session.title.presence || session.display_name), me_session_path(session), class: "hover:text-asmbv-red transition-colors truncate" %>
              </div>
              <div class="mt-1.5 flex items-center gap-2 flex-wrap">
                <%= render BadgeComponent.new(label: "Terrain #{session.terrain.to_s.split('_').last}", variant: :neutral, size: :xs) %>
                <% session.levels.each do |level| %>
                  <%= render BadgeComponent.new(label: level.name, variant: :neutral, size: :xs) %>
                <% end %>
                <span class="inline-flex items-center gap-1 text-xs text-gray-500">
                  <%= lucide_icon("clock", class: "w-3 h-3") %>
                  <%= l session.start_at, format: :default %> — <%= l session.end_at, format: :time %>
                </span>
              </div>
            </div>
            <div class="text-right text-sm text-gray-500 flex-shrink-0">
              <p class="font-semibold text-gray-700"><%= session.user&.full_name || "Organisateur" %></p>
              <p class="text-xs mt-0.5"><%= session.price.to_i %> crédits</p>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-5 py-10 text-center text-gray-400">
        <%= lucide_icon("calendar-x", class: "w-8 h-8 mx-auto mb-2 opacity-40") %>
        <p class="text-sm">Aucune session à venir.</p>
      </div>
    <% end %>
  <% end %>

  <!-- Passées -->
  <%= render CardComponent.new(padding: :none) do %>
    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-3">
      <span class="text-gray-400"><%= lucide_icon("calendar-check", size: 18) %></span>
      <h2 class="text-sm font-bold text-gray-800 uppercase tracking-widest">Passées</h2>
      <% if @past.any? %>
        <span class="text-[10px] font-bold px-1.5 py-0.5 bg-gray-200 text-gray-600 rounded-full leading-none"><%= @past.count %></span>
      <% end %>
    </div>

    <% if @past.any? %>
      <ul class="divide-y divide-gray-100">
        <% @past.each do |session| %>
          <li class="px-5 py-4 flex items-start justify-between gap-4 hover:bg-gray-50/60 transition-colors opacity-80">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 text-gray-700 font-semibold">
                <%= link_to (session.title.presence || session.display_name), me_session_path(session), class: "hover:text-asmbv-red transition-colors truncate" %>
              </div>
              <div class="mt-1.5 flex items-center gap-2 flex-wrap">
                <%= render BadgeComponent.new(label: "Terrain #{session.terrain.to_s.split('_').last}", variant: :neutral, size: :xs) %>
                <% session.levels.each do |level| %>
                  <%= render BadgeComponent.new(label: level.name, variant: :neutral, size: :xs) %>
                <% end %>
                <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                  <%= lucide_icon("clock", class: "w-3 h-3") %>
                  <%= l session.start_at, format: :default %> — <%= l session.end_at, format: :time %>
                </span>
              </div>
            </div>
            <div class="text-right text-sm text-gray-400 flex-shrink-0">
              <p class="font-semibold"><%= session.user&.full_name || "Organisateur" %></p>
              <p class="text-xs mt-0.5"><%= session.price.to_i %> crédits</p>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-5 py-10 text-center text-gray-400">
        <%= lucide_icon("history", class: "w-8 h-8 mx-auto mb-2 opacity-40") %>
        <p class="text-sm">Aucune session passée.</p>
      </div>
    <% end %>
  <% end %>

</div>
