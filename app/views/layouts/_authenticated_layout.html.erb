<!-- Layout pour utilisateurs connectés -->
<div class="min-h-screen"
     <% if user_signed_in? && vapid_public_key.present? %>
     data-controller="push-notifications"
     data-push-notifications-vapid-public-key-value="<%= vapid_public_key %>"
     <% end %>>
  <%= render "layouts/navbar" %>

  <% unless controller_path.start_with?("admin/") %>
    <% if content_for?(:hero) %>
      <%= yield :hero %>
    <% else %>
      <%= render HeroComponent.new(title: default_hero_title) %>
    <% end %>
  <% end %>

  <main class="p-4 sm:p-6 lg:p-8">
    <%= yield %>
  </main>
</div>
