<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      /* Email styles need to be inline */
    </style>
  </head>

  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1f2937; margin: 0; padding: 0; background-color: #ffffff;">
    <div style="max-width: 600px; margin: 0 auto; padding: 24px;">
      <%= yield %>

      <%# Signature partenaire Captive — logo + tagline, le tout cliquable %>
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-top: 48px; border-collapse: collapse;">
        <tr>
          <td style="background-color: #f5f6f8; border-radius: 12px; padding: 32px 24px; text-align: center;">
            <a href="https://www.captive.fr/?utm_source=as_monaco_volley&utm_medium=email&utm_campaign=partner_visibility&utm_content=notification_footer"
               target="_blank"
               style="text-decoration: none; border: 0; display: inline-block;">
              <%= image_tag attachments[ApplicationMailer::CAPTIVE_LOGO_CID].url,
                            alt: "Captive",
                            width: 160,
                            style: "display: block; max-width: 160px; height: auto; margin: 0 auto; border: 0;" %>
            </a>

            <p style="margin: 20px 0 0; font-size: 14px; line-height: 1.6;">
              <a href="https://www.captive.fr/?utm_source=as_monaco_volley&utm_medium=email&utm_campaign=partner_visibility&utm_content=notification_footer"
                 target="_blank"
                 style="color: #4b5563; text-decoration: none;">
                Cette application a été imaginée et développée par <strong style="color: #002448;">Captive</strong>.
                <br>
                <span style="color: #6b7280;">Curieux de savoir qui se cache derrière votre application préférée&nbsp;?</span>
              </a>
            </p>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
