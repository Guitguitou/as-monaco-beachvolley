<%# locals: session:, registration:, conflict:, relevant:, not_enough_credits:, open_ok:, open_reason: %>
<% accent = case session.session_type
           when "entrainement" then :training
           when "jeu_libre" then :free_play
           when "coaching_prive" then :private_coaching
           when "tournoi" then :tournament
           when "stage" then :stage
           end %>

<%= render CardComponent.new(href: session_path(session), accent: accent, padding: :lg) do |card| %>
  <% card.with_header do %>
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <%= render BadgeComponent.new(
            label: get_session_type_label(session.session_type),
            variant: accent ? :"type_#{accent}" : :neutral
          ) %>
        </div>
        <div class="mt-2 text-[13px] font-bold text-gray-900 truncate uppercase tracking-wide">
          <%= session.title.presence || session.display_name %>
        </div>
        <div class="mt-2 text-xs text-gray-700">
          <%= l(session.start_at, format: :default).to_s.downcase %>
        </div>
      </div>

      <div class="text-xs text-gray-600 text-right">
        <div class="font-semibold"><%= session.terrain.to_s.split("_").last %></div>
      </div>
    </div>
  <% end %>

  <div class="space-y-2 text-xs text-gray-700">
    <div class="flex items-center gap-2">
      <%= lucide_icon("clock", class: "w-4 h-4 text-asmbv-red") %>
      <%= l(session.start_at, format: :time) %> · <%= ((session.end_at - session.start_at) / 60).to_i %> min
    </div>
    <div class="flex items-center gap-2">
      <%= lucide_icon("user", class: "w-4 h-4 text-asmbv-red") %>
      <%= session.user&.full_name || "Organisateur" %>
    </div>

    <% if session.max_players.present? %>
      <% confirmed_count = session.registrations.loaded? ? session.registrations.count(&:confirmed?) : session.registrations.confirmed.count %>
      <div class="flex items-center gap-2">
        <%= lucide_icon("users", class: "w-4 h-4 text-asmbv-red") %>
        <%= confirmed_count %>/<%= session.max_players %>
      </div>
      <%= render ProgressBarComponent.new(value: confirmed_count, max: session.max_players, variant: accent || :primary, height: :sm) %>
    <% end %>
  </div>

  <div class="mt-4 border-t border-gray-100 pt-3 flex items-end justify-between gap-3">
    <div class="text-xs text-gray-700">
      <span class="text-2xl font-bold text-asmbv-red"><%= session.price.to_i %></span>
      crédit(s)
    </div>
    <div class="text-xs font-semibold text-asmbv-red uppercase tracking-wide">
      Détails →
    </div>
  </div>

  <div class="mt-3 flex flex-wrap gap-2">
    <% if registration&.confirmed? %>
      <%= render BadgeComponent.new(label: "Inscrit", variant: :success, icon: "check-circle") %>
    <% elsif registration&.waitlisted? %>
      <%= render BadgeComponent.new(label: "Waitlist", variant: :warning, icon: "clock") %>
    <% end %>
    <% unless relevant %>
      <%= render BadgeComponent.new(label: "Hors niveau", variant: :neutral, icon: "sparkles") %>
    <% end %>
    <% if conflict %>
      <%= render BadgeComponent.new(label: "Conflit", variant: :purple, icon: "alert-triangle") %>
    <% end %>
    <% if not_enough_credits %>
      <%= render BadgeComponent.new(label: "Crédits", variant: :danger, icon: "wallet") %>
    <% end %>
    <% unless open_ok %>
      <%= render BadgeComponent.new(label: "Fermé", variant: :info, icon: "door-closed") %>
    <% end %>
  </div>
<% end %>

