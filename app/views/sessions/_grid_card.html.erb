<%# locals: session:, registration:, conflict:, relevant:, not_enough_credits:, open_ok:, open_reason: %>
<%= link_to session_path(session),
      class: "group block rounded-xl border p-4 shadow-sm transition hover:shadow-md #{sessions_type_border_class(session)} #{sessions_type_bg_class(session)}" do %>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="text-sm font-semibold text-gray-900 truncate">
        <%= session.title.presence || session.display_name %>
      </div>
      <div class="mt-1 text-xs text-gray-600 flex items-center gap-2 flex-wrap">
        <span class="inline-flex items-center gap-1">
          <%= lucide_icon("clock", class: "w-3 h-3 text-gray-400") %>
          <%= l(session.start_at, format: :default) %> — <%= l(session.end_at, format: :time) %>
        </span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-100 text-gray-800 text-xs font-semibold">
          <%= lucide_icon("map-pin", class: "w-3 h-3") %> <%= session.terrain.to_s.split("_").last %>
        </span>
      </div>
    </div>

    <div class="text-right text-xs text-gray-600 flex-shrink-0">
      <div class="font-semibold"><%= session.user&.full_name || "Organisateur" %></div>
      <div><%= session.price.to_i %> crédits</div>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap gap-2">
    <% if registration&.confirmed? %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-100 text-green-800 text-xs font-semibold">
        <%= lucide_icon("check-circle", class: "w-3 h-3") %> Inscrit
      </span>
    <% elsif registration&.waitlisted? %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-800 text-xs font-semibold">
        <%= lucide_icon("clock", class: "w-3 h-3") %> Liste d’attente
      </span>
    <% end %>

    <% unless relevant %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-100 text-gray-800 text-xs font-semibold">
        <%= lucide_icon("sparkles", class: "w-3 h-3") %> Hors niveau
      </span>
    <% end %>

    <% if conflict %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-purple-100 text-purple-800 text-xs font-semibold">
        <%= lucide_icon("alert-triangle", class: "w-3 h-3") %> Conflit horaire
      </span>
    <% end %>

    <% if not_enough_credits %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-100 text-red-800 text-xs font-semibold">
        <%= lucide_icon("wallet", class: "w-3 h-3") %> Pas assez de crédits
      </span>
    <% end %>

    <% unless open_ok %>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-blue-100 text-blue-800 text-xs font-semibold">
        <%= lucide_icon("door-closed", class: "w-3 h-3") %>
        <%= open_reason.presence || "Inscriptions fermées" %>
      </span>
    <% end %>
  </div>

  <% if session.levels.any? %>
    <div class="mt-3 text-xs text-gray-700">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold"
            style="background-color: <%= session.levels.first&.color || '#eee' %>22; color: <%= session.levels.first&.color || '#333' %>">
        <%= session.levels.map(&:name).join(", ") %>
      </span>
    </div>
  <% end %>
<% end %>

