<%# Inline errors under fields + global block for :base and summary %>

<div class="max-w-4xl mx-auto mt-10 bg-white p-8 rounded-lg shadow-md">
  <%= form_with model: session, 
                url: session.persisted? ? session_path(session) : sessions_path, 
                method: session.persisted? ? :put : :post, 
                data: { controller: "session-form", session_form_prices_value: Session::PRICE_BY_TYPE },
                class: "space-y-12" do |f| %>

    <% sessions_index_return_params.each do |key, value| %>
      <%= hidden_field_tag key, value %>
    <% end %>

    <%= render "shared/form_errors", object: session %>

    <div class="border-b border-gray-200 pb-8">
      <h2 class="text-lg font-semibold text-gray-900">Informations de la session</h2>

      <div class="mt-8 grid grid-cols-1 gap-x-6 gap-y-6 sm:grid-cols-2">
        
        <!-- Titre -->
        <div class="sm:col-span-2">
          <%= render FormFieldComponent.new(form: f, attribute: :title, type: :text_field, label: "Titre", required: true) %>
        </div>

        <!-- Description -->
        <div class="sm:col-span-2">
          <%= render FormFieldComponent.new(form: f, attribute: :description, type: :text_area, label: "Description", html_options: { rows: 3 }) %>
        </div>

        <!-- Type -->
        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :session_type,
            type: :select,
            label: "Type de session",
            required: true,
            options: options_for_select(Session.session_types.keys.map { |t| [t.humanize, t] }, session.session_type),
            html_options: { data: { session_form_target: "type", action: "session-form#onTypeChange" } }
          ) %>
        </div>

        <!-- Terrain -->
        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :terrain,
            type: :select,
            label: "Terrain",
            required: true,
            options: options_for_select(Session.terrains.keys, session.terrain)
          ) %>
        </div>

        <!-- Coach / Responsable / Organisateur -->
        <div class="sm:col-span-2 hidden" data-session-form-target="userGroupCoach">
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :user_id,
            type: :select,
            label: "Coach",
            required: true,
            options: options_from_collection_for_select(User.coachs, :id, :full_name, session.user_id)
          ) %>
        </div>

        <div class="sm:col-span-2 hidden" data-session-form-target="userGroupResponsable">
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :user_id,
            type: :select,
            label: "Responsable",
            required: true,
            options: options_from_collection_for_select(User.responsables, :id, :full_name, session.user_id)
          ) %>
        </div>

        <div class="sm:col-span-2 hidden" data-session-form-target="userGroupAll">
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :user_id,
            type: :select,
            label: "Organisateur",
            required: true,
            options: options_from_collection_for_select(User.all, :id, :full_name, session.user_id)
          ) %>
        </div>

        <!-- Dates -->
        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :start_at,
            type: :datetime_local_field,
            label: "Date de début",
            required: true,
            html_options: {
              step: 900,
              data: {
                session_form_target: "startAt",
                action: "change->session-form#onStartChange input->session-form#onStartChange blur->session-form#onStartChange"
              }
            }
          ) %>
        </div>

        

        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :end_at,
            type: :datetime_local_field,
            label: "Date de fin",
            required: true,
            html_options: {
              step: 900,
              data: { session_form_target: "endAt", action: "input->session-form#onEndChange change->session-form#onEndChange" }
            }
          ) %>
          <!-- Hidden mirror to ensure value is submitted even if readOnly/disabled quirks occur -->
          <%= hidden_field_tag "session[end_at]", session.end_at&.strftime('%Y-%m-%dT%H:%M'), data: { session_form_target: "endAtHidden" } %>
        </div>

        <!-- Max joueurs -->
        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :max_players,
            type: :number_field,
            label: "Nombre maximum de joueurs",
            html_options: { min: 1 }
          ) %>
        </div>

        <!-- Prix (crédits) -->
        <div>
          <%= render FormFieldComponent.new(
            form: f,
            attribute: :price,
            type: :number_field,
            label: "Prix (crédits)",
            input_class: "block w-full rounded-md border border-gray-300 bg-gray-100 px-3 py-2 text-gray-900 focus:border-asmbv-red focus:ring-2 focus:ring-asmbv-red sm:text-sm",
            html_options: { min: 0, step: 1, readonly: true, data: { session_form_target: "price" } }
          ) %>
        </div>

        <!-- Niveaux -->
        <div class="sm:col-span-2">
          <%= f.label :level_ids, "Niveaux", class: "block text-sm font-medium text-gray-900" %>
          <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2">
            <%= f.collection_check_boxes :level_ids, Level.all, :id, :name do |b| %>
              <div class="flex items-center">
                <%= b.check_box(class: "h-4 w-4 text-asmbv-red border-gray-300 rounded focus:ring-asmbv-red") %>
                <%= b.label(class: "ml-2 text-sm text-gray-700") do %>
                  <%= "#{b.object.name} - #{b.object.gender.humanize}" %>
                <% end %>
              </div>
            <% end %>
          </div>
          <% if session.errors[:level_ids].any? %>
            <p class="mt-1 text-sm text-red-600"><%= session.errors[:level_ids].first %></p>
          <% end %>
        </div>

      </div>
    </div>

    <!-- Participants (multi-sélection avec recherche) -->
    <div class="sm:col-span-2">
      <h3 class="text-sm font-medium text-gray-900 mb-2">Participants</h3>
      <% candidate_users = if session.coaching_prive? 
                             User.all
                           else
                             User.with_enough_credits(session)
                           end %>
      <%= select_tag "session[participant_ids][]",
          options_for_select(
            candidate_users.map { |u| ["#{u.full_name}#{session.coaching_prive? ? '' : " (#{u.balance&.amount} cr)"}", u.id] },
            session.participants.pluck(:id)
          ),
          multiple: true,
          class: "block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 focus:border-asmbv-red focus:ring-2 focus:ring-asmbv-red sm:text-sm",
          data: { controller: "select", select_placeholder_value: "Rechercher des participants..." }
      %>
      <% unless session.coaching_prive? %>
        <p class="mt-1 text-xs text-gray-500">Seuls les membres avec suffisamment de crédits pour cette session sont affichés.</p>
      <% else %>
        <p class="mt-1 text-xs text-gray-500">Coaching privé: les participants ne sont pas débités.</p>
      <% end %>
    </div>

    <!-- Bouton -->
    <div class="flex items-center justify-end gap-x-4">
      <%= link_to "Annuler", sessions_path(sessions_index_return_params), class: "text-sm font-medium text-gray-500 hover:text-gray-700" %>
      <%= f.submit "Enregistrer", 
            class: "inline-flex items-center rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white shadow-sm 
                    hover:bg-asmbv-red-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-asmbv-red" %>
    </div>
  <% end %>
</div>
