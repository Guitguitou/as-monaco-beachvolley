<% calendar_ctx = sessions_index_return_params %>
<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
  <% @session.registrations.confirmed.includes(user: :levels).each do |registration| %>
    <% user = registration.user
       initials = if user.first_name.present? && user.last_name.present?
                    "#{user.first_name.strip[0]}#{user.last_name.strip[0]}".upcase
                  elsif user.full_name.present?
                    parts = user.full_name.split
                    parts.size >= 2 ? "#{parts[0][0]}#{parts[1][0]}".upcase : user.full_name[0, 2].to_s.upcase
                  else
                    "?"
                  end %>
    <div class="flex items-center gap-3 p-3 bg-gray-50 border border-gray-200 rounded-none hover:bg-gray-100 transition-colors">
      <div class="h-9 w-9 shrink-0 bg-asmbv-red/10 text-asmbv-red flex items-center justify-center text-xs font-bold rounded-none">
        <%= initials %>
      </div>
      <div class="flex-1 min-w-0 flex items-center justify-between gap-2">
        <div class="min-w-0">
          <div class="font-medium text-sm text-gray-900 truncate"><%= user.full_name %></div>
          <% level_names = user.levels.map(&:name).join(", ") %>
          <% if level_names.present? %>
            <div class="text-xs text-gray-500 truncate"><%= level_names %></div>
          <% end %>
        </div>
        <% can_remove = if Time.current <= @session.end_at
          current_user&.admin? || current_user == @session.user
        else
          current_user&.admin?
        end %>
        <% if can_remove %>
          <%= button_to session_registration_path(@session, calendar_ctx.merge(user_id: registration.user_id)), method: :delete,
                        form: { data: { turbo_confirm: "Retirer #{user.full_name} ?" }, class: "shrink-0" },
                        class: "inline-flex items-center gap-1 rounded-none px-2 py-1 text-xs font-semibold text-white bg-red-600 hover:bg-red-500" do %>
            <%= lucide_icon("trash-2", class: "w-3 h-3", aria: { hidden: true }) %>
            Retirer
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% waitlisted = @session.registrations.waitlisted.order(:created_at) %>
<% if waitlisted.any? %>
  <div class="mt-5">
    <h4 class="text-xs font-bold uppercase tracking-wide text-gray-900 mb-3 mt-3">Liste d’attente</h4>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
    <% waitlisted.each_with_index do |registration, index| %>
      <div class="flex items-center justify-between gap-3 p-3 bg-orange-50 text-orange-900 rounded-none border border-orange-200">
        <div class="flex items-center gap-2 min-w-0">
          <span class="inline-flex items-center justify-center w-6 h-6 text-xs font-bold bg-orange-200 text-orange-900 rounded-none shrink-0"><%= index + 1 %></span>
          <span class="font-medium text-sm truncate"><%= registration.user.full_name %></span>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <span class="text-xs">En attente</span>
          <% can_remove = if Time.current <= @session.end_at
            current_user&.admin? || current_user == @session.user
          else
            current_user&.admin?
          end %>
          <% if can_remove %>
            <%= button_to session_registration_path(@session, calendar_ctx.merge(user_id: registration.user_id)), method: :delete,
                          form: { data: { turbo_confirm: "Retirer #{registration.user.full_name} de la liste d'attente ?" } },
                          class: "inline-flex items-center gap-1 rounded-none px-2 py-1 text-xs font-semibold text-white bg-red-600 hover:bg-red-500" do %>
              <%= lucide_icon("trash-2", class: "w-3 h-3", aria: { hidden: true }) %>
              Retirer
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# Inline add form moved to a side card on show page %>
