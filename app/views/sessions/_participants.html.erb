<div class="flex flex-col gap-2">
  <% @session.registrations.confirmed.includes(:user).each do |registration| %>
    <div class="flex items-center justify-between px-3 py-2 bg-gray-50 rounded-none border border-gray-200">
      <div class="flex items-center gap-2">
        <%= lucide_icon("user", class: "w-4 h-4 text-gray-500") %>
        <span><%= registration.user.full_name %></span>
      </div>
      <% can_remove = if Time.current <= @session.end_at
        current_user&.admin? || current_user == @session.user
      else
        current_user&.admin?
      end %>
      <% if can_remove %>
        <%= button_to session_registration_path(@session, user_id: registration.user_id), method: :delete,
                      form: { data: { turbo_confirm: "Retirer #{registration.user.full_name} ?" } },
                      class: "inline-flex items-center gap-1 rounded-none px-3 py-1.5 text-sm font-semibold text-white bg-red-600 hover:bg-red-500" do %>
          <%= lucide_icon("trash-2", class: "w-4 h-4") %>
          Retirer
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<% waitlisted = @session.registrations.waitlisted.order(:created_at) %>
<% if waitlisted.any? %>
  <div class="mt-5">
    <h4 class="text-xs font-bold uppercase tracking-wide text-gray-900 mb-3">Liste d’attente</h4>
  </div>
  <div class="flex flex-col gap-2">
    <% waitlisted.each_with_index do |registration, index| %>
      <div class="flex items-center justify-between px-3 py-2 bg-yellow-50 text-yellow-800 rounded-none border border-yellow-200">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-6 h-6 text-xs font-bold bg-yellow-200 text-yellow-800 rounded-none"><%= index + 1 %></span>
          <span><%= registration.user.full_name %></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs">En attente</span>
          <% can_remove = if Time.current <= @session.end_at
            current_user&.admin? || current_user == @session.user
          else
            current_user&.admin?
          end %>
          <% if can_remove %>
            <%= button_to session_registration_path(@session, user_id: registration.user_id), method: :delete,
                          form: { data: { turbo_confirm: "Retirer #{registration.user.full_name} de la liste d'attente ?" } },
                          class: "inline-flex items-center gap-1 rounded-none px-2 py-1 text-xs font-semibold text-white bg-red-600 hover:bg-red-500" do %>
              <%= lucide_icon("trash-2", class: "w-3 h-3") %>
              Retirer
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# Inline add form moved to a side card on show page %>
