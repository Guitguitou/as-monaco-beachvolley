<% registered_sessions = Array(@sessions_registered_grid) %>
<% eligible_sessions = Array(@sessions_eligible_grid) %>
<% sessions_empty = registered_sessions.empty? && eligible_sessions.empty? %>

<% if sessions_empty %>
  <%= render CardComponent.new(padding: :lg, class_name: "mt-6 text-center") do %>
    <p class="text-sm text-gray-500">Aucune session à venir.</p>
<% end %>
<% else %>
  <% conflict_ids = Array(@conflict_session_ids).map(&:to_i).to_h { |id| [id, true] } %>
  <% regs = @registrations_by_session_id || {} %>
  <% user_level_ids = Array(@user_level_ids).map(&:to_i) %>
  <% user_balance = @user_balance_amount.to_i %>

  <% if registered_sessions.any? %>
    <div class="mt-6">
      <h2 class="text-sm font-bold uppercase tracking-wide text-gray-900">Mes sessions à venir</h2>
      <p class="mt-1 text-xs text-gray-600">Sessions où tu es inscrit ou en liste d’attente.</p>
    </div>

    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% registered_sessions.each do |session| %>
        <% reg = regs[session.id] %>
        <% open_ok, open_reason = session.registration_open_state_for(current_user) %>
        <% not_enough_credits = !session.coaching_prive? && user_balance < session.price.to_i %>
        <% conflict = reg.blank? && conflict_ids[session.id] %>
        <% relevant = if session.entrainement? && session.levels.any?
                        (session.level_ids & user_level_ids).any?
                      else
                        true
                      end %>

        <%= render "grid_card",
              session: session,
              registration: reg,
              conflict: conflict,
              relevant: relevant,
              not_enough_credits: not_enough_credits,
              open_ok: open_ok,
              open_reason: open_reason %>
      <% end %>
    </div>
  <% end %>

  <% if eligible_sessions.any? %>
    <div class="<%= registered_sessions.any? ? 'mt-10' : 'mt-6' %>">
      <h2 class="text-sm font-bold uppercase tracking-wide text-gray-900">Sessions où je peux m’inscrire</h2>
    </div>

    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% eligible_sessions.each do |session| %>
      <% reg = regs[session.id] %>
      <% open_ok, open_reason = session.registration_open_state_for(current_user) %>
      <% not_enough_credits = !session.coaching_prive? && user_balance < session.price.to_i %>
      <% conflict = reg.blank? && conflict_ids[session.id] %>
      <% relevant = if session.entrainement? && session.levels.any?
                      (session.level_ids & user_level_ids).any?
                    else
                      true
                    end %>

      <%= render "grid_card",
            session: session,
            registration: reg,
            conflict: conflict,
            relevant: relevant,
            not_enough_credits: not_enough_credits,
            open_ok: open_ok,
            open_reason: open_reason %>
      <% end %>
    </div>
  <% end %>
<% end %>

