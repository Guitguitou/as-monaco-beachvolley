<%# Content-only partial (wrapped in a Card in `sessions/show`) %>
<div class="grid grid-cols-1 gap-4">
  <div>
    <div class="space-y-3">
      <div class="flex items-center gap-3">
        <%= lucide_icon('calendar', class: 'w-5 h-5 text-gray-400') %>
        <div>
          <div class="font-medium text-gray-900">Date et heure</div>
          <div class="text-gray-600">
            <%= l @session.start_at, format: :default %> - <%= l @session.end_at, format: :time %>
          </div>
        </div>
      </div>

      <% if @session.user %>
        <div class="flex items-center gap-3">
          <%= lucide_icon('user', class: 'w-5 h-5 text-gray-400') %>
          <div>
            <div class="font-medium text-gray-900">Organisateur</div>
            <div class="text-gray-600"><%= @session.user.full_name %></div>
          </div>
        </div>
      <% end %>

      <% if @session.max_players %>
        <div class="flex items-center gap-3">
          <%= lucide_icon('users', class: 'w-5 h-5 text-gray-400') %>
          <div>
            <div class="font-medium text-gray-900">Places disponibles</div>
            <div class="text-gray-600"><%= @session.max_players %> joueurs maximum</div>
          </div>
        </div>
      <% end %>
      <div class="flex items-center gap-3">
        <%= lucide_icon('layers', class: 'w-5 h-5 text-gray-400') %>
        <div>
          <div class="font-medium text-gray-900">Niveaux</div>
          <div class="text-gray-600">
            <% if @session.levels.any? %>
              <%= @session.levels.map(&:name).join(', ') %>
            <% else %>
              Tous niveaux
            <% end %>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-3">
          <%= lucide_icon('banknote-arrow-down', class: 'w-5 h-5 text-gray-400') %>
          <div>
            <div class="font-medium text-gray-900">Prix</div>
            <div class="text-gray-600"><%= @session.price.to_i %> crédits</div>
          </div>
        </div>
      <% if @session.entrainement? && @session.registration_opens_at.present? %>
        <div class="flex items-center gap-3">
          <%= lucide_icon('door-open', class: 'w-5 h-5 text-gray-400') %>
          <div>
            <div class="font-medium text-gray-900">Ouverture des inscriptions</div>
            <div class="text-gray-600">
              <%= l @session.registration_opens_at, format: :default %>
              <% within_priority = Time.current < (@session.registration_opens_at + Session::PRIORITY_WINDOW_HOURS.hours) %>
              <% if Time.current < @session.registration_opens_at %>
                <span class="ml-2"><%= render BadgeComponent.new(label: "Pas encore ouvert", variant: :neutral, size: :xs) %></span>
              <% elsif within_priority %>
                <span class="ml-2"><%= render BadgeComponent.new(label: "Priorité compétition (24h)", variant: :info, size: :xs) %></span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
      <% if @session.entrainement? && @session.cancellation_deadline_at.present? %>
        <div class="flex items-center gap-3">
          <%= lucide_icon('alarm-clock', class: 'w-5 h-5 text-gray-400') %>
          <div>
            <div class="font-medium text-gray-900">Date limite de désinscription</div>
            <div class="text-gray-600">
              <%= l @session.cancellation_deadline_at, format: :default %>
              <% if Time.current > @session.cancellation_deadline_at %>
                <span class="ml-2"><%= render BadgeComponent.new(label: "Délai dépassé", variant: :danger, size: :xs) %></span>
              <% else %>
                <span class="ml-2"><%= render BadgeComponent.new(label: "Remboursement non garanti après", variant: :warning, size: :xs) %></span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
