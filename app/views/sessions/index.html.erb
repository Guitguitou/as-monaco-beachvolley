<div class="mb-4">
  <!-- Titre -->
  <div class="flex flex-col items-center sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 text-center sm:text-left">
    <h1 class="text-xl sm:text-2xl font-bold flex items-center gap-2 justify-center">
      <%= lucide_icon("calendar") %> Mon calendrier
    </h1>
    
    <div class="flex items-center gap-2 w-full sm:w-auto justify-center">
      <% current_view = @view.presence || params[:view].presence || "calendar" %>
      <%= button(
        "Grille",
        variant: (current_view == "grid" ? :primary : :ghost),
        size: :small,
        href: sessions_path(request.query_parameters.merge(view: "grid")),
        icon: nil
      ) %>
      <%= button(
        "Calendrier",
        variant: (current_view == "calendar" ? :primary : :ghost),
        size: :small,
        href: sessions_path(request.query_parameters.merge(view: "calendar")),
        icon: nil
      ) %>
    </div>

    <% if can?(:create, Session) %>
      <%= button("Nouvelle session", variant: :primary, size: :small, href: new_session_path(sessions_index_return_params)) %>
    <% end %>
  </div>
  
  <!-- Filtres de terrain -->
  <%= render "terrain_filter" %>
</div>

<% if (@view.presence || params[:view].presence || "calendar") == "grid" %>
  <%= render "grid" %>
<% else %>
<% if @terrain_closures_week.present? %>
  <div class="mb-3 rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-950">
    <p class="font-medium flex items-center gap-2">
      <%= lucide_icon("ban", size: 16) %> Terrains indisponibles cette semaine
    </p>
    <ul class="mt-2 space-y-1 list-disc list-inside text-amber-900">
      <% @terrain_closures_week.each do |c| %>
        <li>
          <span class="font-semibold"><%= c.terrain %></span>
          : du <%= l(c.starts_on, format: :default) %> au <%= l(c.ends_on, format: :default) %>
          <% if c.reason.present? %>
            <span class="text-amber-800">— <%= c.reason %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
<%
  user_level_ids = current_user.levels.pluck(:id)
  sessions_json = @sessions.map do |s|
    case s.terrain
    when 'Terrain 1'
      bg, border, text = ['#ef4444', '#b91c1c', '#ffffff'] # rouge
    when 'Terrain 2'
      bg, border, text = ['#111827', '#0b1220', '#ffffff'] # noir
    when 'Terrain 3'
      bg, border, text = ['#D4AF37', '#b08e2d', '#111827'] # doré
    else
      bg, border, text = ['#e5e7eb', '#d1d5db', '#111827'] # gris par défaut
    end

    short = s.display_name
      .gsub(/Entra[iî]nement/i, 'Entr.')
      .gsub(/\s*–\s*/, ' ')
      .gsub(/\s+Groupe\s*/i, 'G')
      .gsub(/\s+Mixte/i, ' Mx')

    {
      id: s.id,
      title: s.display_name,
      shortTitle: short,     # <-- ajouté
      start: s.start_at.iso8601,
      end: s.end_at.iso8601,
      url: sessions_calendar_event_path(s),
      backgroundColor: bg,
      borderColor: border,
      textColor: text,
      terrain: s.terrain,
      forMe: (!s.entrainement? || s.levels.empty? || (s.level_ids & user_level_ids).any?),
      coachName: s.user&.full_name || '-'
    }
  end.to_json
%>

<div
  id="calendar"
  data-controller="calendar"
  data-initial-date="<%= params[:date] %>"
  data-sessions="<%= json_escape(sessions_json) %>"
  class="mt-4 bg-white p-2 sm:p-4 rounded-none">
</div>
<% end %>
