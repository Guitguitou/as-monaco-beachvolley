<%# locals: session: %>
<div class="flex items-center justify-between gap-3">
  <%= link_to sessions_path(sessions_index_return_params), class: "inline-flex items-center gap-2 text-sm font-semibold text-white/90 hover:text-white" do %>
    <%= lucide_icon("arrow-left", class: "w-4 h-4 shrink-0") %>
    Retour aux sessions
  <% end %>

  <div class="flex items-center gap-2">
    <% if user_signed_in? && current_user.admin? %>
      <%= link_to edit_admin_session_path(session), class: "inline-flex items-center gap-2 rounded-none border border-white/40 bg-white/10 px-3 py-2 text-sm font-semibold text-white hover:bg-white/15" do %>
        <%= lucide_icon("edit", class: "w-4 h-4 shrink-0") %>
        Modifier
      <% end %>
    <% end %>
  </div>
</div>
