<div class="max-w-6xl mx-auto space-y-8" data-controller="player-listing-tutorial tabs">
  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Pour Toi</h1>
      <p class="text-sm text-gray-500">Tes sessions a venir et les opportunites pour trouver des partenaires.</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <button type="button" data-action="player-listing-tutorial#open" class="inline-flex items-center gap-2 rounded-md border border-gray-300 px-3 py-2 text-xs font-semibold text-gray-600 hover:bg-gray-50" title="Comment ça marche ?">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Comment ça marche ?
      </button>
      <%= button_to player_suggestions_preferences_path,
            method: :patch,
            params: { enabled: !current_user.player_suggestions_push_enabled? },
            class: "inline-flex items-center rounded-md border border-gray-300 px-3 py-2 text-xs font-semibold text-gray-700 hover:bg-gray-50" do %>
        <%= current_user.player_suggestions_push_enabled? ? "Desactiver les push" : "Activer les push" %>
      <% end %>
    </div>
  </div>

  <%# Onglets principaux: Mes sessions | On joue? %>
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <nav class="flex border-b border-gray-200">
      <button type="button" data-tabs-target="tab" data-tab="sessions" data-action="click->tabs#switch" class="px-6 py-4 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        Mes sessions
      </button>
      <button type="button" data-tabs-target="tab" data-tab="on-joue" data-action="click->tabs#switch" class="px-6 py-4 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        On joue ?
      </button>
    </nav>

    <%# Panel 1: Mes sessions (entrainement, jeu libre, tournoi) %>
    <div data-tabs-target="panel" data-panel="sessions" class="p-6">
      <% if @upcoming_sessions.any? %>
        <div class="space-y-3">
          <% @upcoming_sessions.each do |session| %>
            <% is_registered = @confirmed_session_ids.include?(session.id) %>
            <%= link_to session_path(session), class: "block border rounded-lg p-4 transition #{is_registered ? 'border-green-300 bg-green-50/50' : 'border-gray-200 hover:border-gray-300 hover:bg-gray-50/50'}" do %>
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="font-semibold text-gray-900"><%= session.title %></span>
                    <span class="px-2 py-0.5 rounded text-xs font-medium <%= get_session_type_classes(session.session_type) %>"><%= get_session_type_label(session.session_type) %></span>
                    <span class="text-xs text-gray-500"><%= session.terrain %></span>
                  </div>
                  <div class="mt-1 text-sm text-gray-600">
                    <%= l(session.start_at, format: :short) %> - <%= session.end_at.strftime("%H:%M") %>
                  </div>
                  <% if session.levels.any? %>
                    <div class="mt-1 text-xs text-gray-500">Niveaux: <%= session.levels.map(&:display_name).join(", ") %></div>
                  <% end %>
                </div>
                <div class="shrink-0">
                  <% if is_registered %>
                    <span class="inline-flex items-center gap-1 rounded-md bg-green-100 px-2.5 py-1 text-xs font-medium text-green-800">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                      Inscrit
                    </span>
                  <% elsif session.full? %>
                    <span class="inline-flex rounded-md bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700">Complet</span>
                  <% else %>
                    <span class="inline-flex rounded-md bg-asmbv-red/10 px-2.5 py-1 text-xs font-medium text-asmbv-red">Voir</span>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">Aucune session a venir pour le moment.</p>
      <% end %>
    </div>

    <%# Panel 2: On joue? (sessions ouvertes, joueurs compatibles, formulaire) %>
    <div data-tabs-target="panel" data-panel="on-joue" class="hidden p-6 space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="space-y-3">
          <h3 class="text-sm font-semibold text-gray-700">Sessions ouvertes (places dispo)</h3>
          <% if @open_sessions.any? %>
            <% @open_sessions.each do |session| %>
              <div class="border border-gray-200 rounded-md p-3 space-y-2">
                <div class="flex items-center justify-between">
                  <div class="text-sm font-semibold text-gray-900"><%= session.title %></div>
                  <span class="text-xs text-gray-500"><%= session.terrain %></span>
                </div>
                <div class="text-xs text-gray-500">
                  <%= I18n.l(session.start_at, format: :short) %> - <%= session.end_at.strftime("%H:%M") %>
                </div>
                <div class="text-xs text-gray-600">
                  Places: <%= session.max_players.present? ? "#{[session.max_players - session.registrations.confirmed.count, 0].max} restantes" : "Illimitees" %>
                </div>
                <% if @confirmed_session_ids.include?(session.id) %>
                  <span class="inline-flex rounded-md bg-green-100 px-2 py-1 text-xs font-medium text-green-800">Deja inscrit</span>
                <% elsif session.full? %>
                  <span class="inline-flex rounded-md bg-gray-100 px-2 py-1 text-xs font-medium text-gray-700">Complete</span>
                <% else %>
                  <%= button_to "Je suis interesse", session_registrations_path(session),
                        method: :post,
                        class: "inline-flex items-center rounded-md bg-asmbv-red px-3 py-1.5 text-xs font-semibold text-white hover:bg-asmbv-red-dark" %>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">Aucune session ouverte compatible pour le moment.</p>
          <% end %>
        </div>

        <div class="space-y-3">
          <h3 class="text-sm font-semibold text-gray-700">Joueurs compatibles</h3>
          <% if @suggested_players.any? %>
            <% @suggested_players.each do |listing| %>
              <div class="border border-gray-200 rounded-md p-3 space-y-2">
                <div class="flex items-center justify-between">
                  <div class="text-sm font-semibold text-gray-900"><%= listing.user.full_name %></div>
                  <div class="text-xs text-gray-500"><%= listing.listing_type.humanize %></div>
                </div>
                <div class="text-xs text-gray-500">
                  <%= I18n.l(listing.effective_start_at.to_date, format: :short) %> •
                  <%= listing.effective_start_at.strftime("%H:%M") %> - <%= listing.effective_end_at.strftime("%H:%M") %>
                </div>
                <%= button_to "Contacter", player_requests_path(player_listing_id: listing.id),
                      method: :post,
                      class: "inline-flex items-center rounded-md bg-asmbv-red px-3 py-1.5 text-xs font-semibold text-white hover:bg-asmbv-red-dark" %>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">Aucun joueur compatible pour l'instant.</p>
          <% end %>
        </div>
      </div>

      <hr class="border-gray-200 my-6" />

      <div data-controller="player-listing-wizard">
    <h2 class="text-lg font-semibold text-gray-900">Je suis dispo</h2>

    <nav class="flex border-b border-gray-200">
      <button type="button" data-player-listing-wizard-target="nav" data-step="1" data-action="player-listing-wizard#goTo" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        1. Quand
      </button>
      <button type="button" data-player-listing-wizard-target="nav" data-step="2" data-action="player-listing-wizard#goTo" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        2. Type
      </button>
      <button type="button" data-player-listing-wizard-target="nav" data-step="3" data-action="player-listing-wizard#goTo" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
        3. Preferences
      </button>
    </nav>

    <%= form_with model: @player_listing, url: player_listings_path, class: "space-y-4" do |f| %>
      <div data-player-listing-wizard-target="step" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div>
            <%= f.label :date, "Jour", class: "block text-sm font-medium text-gray-900" %>
            <%= f.date_field :date, class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900" %>
          </div>
          <div>
            <%= f.label :starts_at, "Debut", class: "block text-sm font-medium text-gray-900" %>
            <%= f.time_field :starts_at, class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900" %>
          </div>
          <div>
            <%= f.label :ends_at, "Fin", class: "block text-sm font-medium text-gray-900" %>
            <%= f.time_field :ends_at, class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900" %>
          </div>
        </div>
        <div class="flex justify-end">
          <button type="button" data-action="player-listing-wizard#next" class="inline-flex items-center rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white hover:bg-asmbv-red-dark">
            Suivant
          </button>
        </div>
      </div>

      <div data-player-listing-wizard-target="step" class="hidden space-y-4">
        <div>
          <%= f.label :listing_type, "Type", class: "block text-sm font-medium text-gray-900" %>
          <%= f.select :listing_type,
                options_for_select(PlayerListing.listing_types.keys.map { |t| [t.humanize, t] }, @player_listing.listing_type),
                {}, class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900 max-w-xs" %>
          <p class="mt-1 text-xs text-gray-500">Disponible = je suis dispo. Recherche = je cherche des partenaires.</p>
        </div>
        <div class="flex justify-between">
          <button type="button" data-action="player-listing-wizard#prev" class="inline-flex items-center rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            Retour
          </button>
          <button type="button" data-action="player-listing-wizard#next" class="inline-flex items-center rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white hover:bg-asmbv-red-dark">
            Suivant
          </button>
        </div>
      </div>

      <div data-player-listing-wizard-target="step" class="hidden space-y-4">
        <div>
          <%= f.label :level_ids, "Niveaux", class: "block text-sm font-medium text-gray-900 mb-2" %>
          <div class="flex flex-wrap gap-3">
            <%= f.collection_check_boxes :level_ids, @levels, :id, :display_name do |b| %>
              <label class="flex items-center gap-2 text-sm text-gray-700">
                <%= b.check_box(class: "h-4 w-4 text-asmbv-red border-gray-300 rounded focus:ring-asmbv-red") %>
                <span><%= b.text %></span>
              </label>
            <% end %>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :session_id, "Session liee (optionnel)", class: "block text-sm font-medium text-gray-900" %>
            <%= f.select :session_id,
                  options_for_select(@sessions.map { |s| ["#{s.title} (#{I18n.l(s.start_at, format: :short)})", s.id] }, @player_listing.session_id),
                  { include_blank: "Aucune" },
                  class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900" %>
          </div>
          <div>
            <%= f.label :gender, "Genre", class: "block text-sm font-medium text-gray-900" %>
            <%= f.select :gender,
                  options_for_select(PlayerListing.genders.keys.map { |g| [g.humanize, g] }, @player_listing.gender),
                  { include_blank: "Tous" },
                  class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900" %>
          </div>
        </div>
        <div>
          <%= f.label :notes, "Notes (optionnel)", class: "block text-sm font-medium text-gray-900" %>
          <%= f.text_area :notes, rows: 2,
                class: "mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-gray-900",
                placeholder: "Infos supplementaires..." %>
        </div>
        <div class="flex justify-between">
          <button type="button" data-action="player-listing-wizard#prev" class="inline-flex items-center rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
            Retour
          </button>
          <%= f.submit "Me rendre visible", class: "inline-flex items-center gap-2 rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white hover:bg-asmbv-red-dark" %>
        </div>
      </div>
    <% end %>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        <div class="border border-gray-200 rounded-lg p-4 space-y-3">
          <h2 class="text-lg font-semibold text-gray-900">Mes demandes</h2>
      <% if @incoming_requests.any? %>
        <div class="space-y-3">
          <% @incoming_requests.each do |request| %>
            <div class="border border-gray-200 rounded-md p-3 space-y-2">
              <div class="text-sm font-semibold text-gray-900"><%= request.from_user.full_name %></div>
              <div class="flex items-center gap-2">
                <%= button_to "Accepter", accept_player_request_path(request), method: :patch, class: "inline-flex items-center rounded-md bg-asmbv-red px-2 py-1 text-xs font-semibold text-white hover:bg-asmbv-red-dark" %>
                <%= button_to "Refuser", decline_player_request_path(request), method: :patch, class: "inline-flex items-center rounded-md border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-50" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">Aucune demande recue.</p>
      <% end %>
      <% if @outgoing_requests.any? %>
        <div class="pt-2 border-t border-gray-100 space-y-2">
          <h3 class="text-sm font-semibold text-gray-700">Envoyees</h3>
          <% @outgoing_requests.each do |request| %>
            <div class="text-sm text-gray-600"><%= request.to_user.full_name %> - En attente</div>
          <% end %>
        </div>
      <% end %>
        </div>

        <div class="border border-gray-200 rounded-lg p-4 space-y-3">
          <h2 class="text-lg font-semibold text-gray-900">Mes disponibilites</h2>
      <% if @my_listings.any? %>
        <div class="space-y-3">
          <% @my_listings.each do |listing| %>
            <div class="border border-gray-200 rounded-md p-3 flex items-center justify-between gap-2">
              <div>
                <div class="text-sm font-semibold text-gray-900"><%= listing.listing_type.humanize %></div>
                <div class="text-xs text-gray-500">
                  <%= I18n.l(listing.effective_start_at.to_date, format: :short) %> • <%= listing.effective_start_at.strftime("%H:%M") %> - <%= listing.effective_end_at.strftime("%H:%M") %>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <% if listing.active? %>
                  <%= button_to "Clore", player_listing_path(listing), method: :patch, params: { player_listing: { status: "closed" } }, class: "inline-flex items-center rounded-md border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-50" %>
                <% else %>
                  <%= button_to "Reouvrir", player_listing_path(listing), method: :patch, params: { player_listing: { status: "active" } }, class: "inline-flex items-center rounded-md border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-50" %>
                <% end %>
                <%= button_to "Supprimer", player_listing_path(listing), method: :delete, data: { confirm: "Supprimer cette disponibilite ?" }, class: "inline-flex items-center rounded-md border border-red-200 px-2 py-1 text-xs text-red-700 hover:bg-red-50" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
          <p class="text-sm text-gray-500">Aucune disponibilite active.</p>
      <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Modal tutoriel "Comment ça marche ?" %>
  <div data-player-listing-tutorial-target="modal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-modal="true">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="fixed inset-0 bg-gray-900/60 transition-opacity cursor-pointer" aria-hidden="true" data-action="click->player-listing-tutorial#close"></div>
      <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 space-y-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900">Comment ça marche ?</h3>
          <button type="button" data-action="player-listing-tutorial#close" class="rounded-md p-1 text-gray-400 hover:text-gray-600 hover:bg-gray-100">
            <span class="sr-only">Fermer</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>

        <div class="space-y-4 min-h-[180px]">
          <div data-player-listing-tutorial-target="slide" class="space-y-3">
            <div class="flex items-start gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-asmbv-red/10 text-asmbv-red font-semibold">1</span>
              <div>
                <h4 class="font-medium text-gray-900">Mes sessions</h4>
                <p class="text-sm text-gray-600">Onglet &laquo; Mes sessions &raquo; : tes entraînements, jeux libres et tournois à venir. Les sessions où tu es inscrit sont en vert.</p>
              </div>
            </div>
          </div>
          <div data-player-listing-tutorial-target="slide" class="hidden space-y-3">
            <div class="flex items-start gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-asmbv-red/10 text-asmbv-red font-semibold">2</span>
              <div>
                <h4 class="font-medium text-gray-900">On joue ?</h4>
                <p class="text-sm text-gray-600">Sessions ouvertes (avec places) et joueurs compatibles. Clique sur &laquo; Je suis interesse &raquo; ou &laquo; Contacter &raquo;. Publie ta dispo pour que les autres te trouvent.</p>
              </div>
            </div>
          </div>
          <div data-player-listing-tutorial-target="slide" class="hidden space-y-3">
            <div class="flex items-start gap-3">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-asmbv-red/10 text-asmbv-red font-semibold">3</span>
              <div>
                <h4 class="font-medium text-gray-900">Mes demandes</h4>
                <p class="text-sm text-gray-600">Quand quelqu'un te contacte, tu reçois une demande. Accepte ou refuse, puis coordonnez-vous pour jouer ensemble.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between pt-2 border-t border-gray-200">
          <div class="flex gap-1">
            <span data-player-listing-tutorial-target="indicator" class="h-2 w-2 rounded-full bg-asmbv-red"></span>
            <span data-player-listing-tutorial-target="indicator" class="h-2 w-2 rounded-full bg-gray-300"></span>
            <span data-player-listing-tutorial-target="indicator" class="h-2 w-2 rounded-full bg-gray-300"></span>
          </div>
          <div class="flex gap-2">
            <button type="button" data-player-listing-tutorial-target="prevButton" data-action="player-listing-tutorial#prev" class="text-sm font-medium text-gray-600 hover:text-gray-900">
              Retour
            </button>
            <button type="button" data-player-listing-tutorial-target="nextButton" data-action="player-listing-tutorial#next" class="inline-flex items-center rounded-md bg-asmbv-red px-4 py-2 text-sm font-semibold text-white hover:bg-asmbv-red-dark">
              Suivant
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
